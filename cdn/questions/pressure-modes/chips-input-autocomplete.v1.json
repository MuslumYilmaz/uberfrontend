  "debrief": {
    "title": "You kept invite input predictable under pressure",
    "summary": "You protected identity, keyboard state, hard limits, and assistive-technology feedback while the interaction surface kept expanding.",
    "takeaways": [
      "Normalize at token boundaries and derive suggestions from immutable candidate and chip state.",
      "Treat active option, open state, and focus as one keyboard lifecycle.",
      "Enforce limits in domain handlers even when the visible input is disabled.",
      "Keep combobox relationships and live regions stable across every state transition."
    ],
    "frameworkNotes": {
      "react": "Use memoized suggestions, functional state updates, and effect cleanup for the document listener.",
      "angular": "Use derived getters with immutable chip updates and let the component lifecycle clean up document bindings.",
      "vue": "Use computed suggestions, ref-backed interaction state, and onBeforeUnmount cleanup for the document listener."
    }
  },
