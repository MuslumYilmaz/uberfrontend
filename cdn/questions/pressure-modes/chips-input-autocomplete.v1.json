            },
            {
              "type": "setValue",
              "selector": ".chip-input",
              "value": "Four"
            },
            {
              "type": "key",
              "selector": ".chip-input",
              "key": "Enter"
            },
            {
              "type": "setValue",
              "selector": ".chip-input",
              "value": "Five"
            },
            {
              "type": "key",
              "selector": ".chip-input",
              "key": "Enter"
            },
            {
