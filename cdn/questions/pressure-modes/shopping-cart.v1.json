  "debrief": {
    "title": "You kept cart state correct under pressure",
    "summary": "The final implementation keeps product identity, quantities, inventory, money, promo feedback, checkout, and accessible announcements synchronized through one cart model. The interview signal is preserving every earlier invariant as purchase rules accumulate.",
    "takeaways": [
      "Derive quantities and money from cart lines so every transition has one source of truth.",
      "Enforce stock in every path that can increase quantity, then expose the same boundary in control state and status feedback.",
      "Normalize promo codes at the boundary and derive a single discount from the subtotal instead of accumulating adjustments.",
      "Treat checkout as an explicit reset transition and keep live regions stable while their messages change."
    ],
    "frameworkNotes": {
      "react": "Functional state updates keep cart transitions current, while derived values and stable status elements prevent duplicated purchase state.",
      "angular": "Immutable cart assignments work with derived getters, and standalone template bindings keep disabled and ARIA state synchronized.",
      "vue": "Computed totals derive from the cart ref, while immutable replacements keep product rows and purchase feedback predictable."
    }
  },
