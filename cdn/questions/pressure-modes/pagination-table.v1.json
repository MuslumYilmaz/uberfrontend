            },
            {
              "type": "expectAttribute",
              "selector": ".select-page",
              "attribute": "aria-label",
              "expected": "Select all users on this page"
            },
            {
              "type": "expectAttribute",
              "selector": ".clear-selection",
              "attribute": "aria-label",
              "expected": "Clear selected users"
            },
            {
              "type": "expectAttribute",
              "selector": ".footer",
              "attribute": "role",
              "expected": "navigation"
            },
            {
              "type": "expectAttribute",
              "selector": ".footer",
              "attribute": "aria-label",
              "expected": "Pagination"
            },
            {
              "type": "expectAttribute",
              "selector": ".table-status",
              "attribute": "role",
              "expected": "status"
            },
            {
              "type": "expectAttribute",
              "selector": ".table-status",
