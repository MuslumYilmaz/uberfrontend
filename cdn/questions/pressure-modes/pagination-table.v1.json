              "text": "Search cleared. 13 users found."
            },
            {
              "type": "unmountPreview"
            },
            {
              "type": "expectNoPreviewTimers"
            }
          ]
        }
      ]
    }
  ],
  "debrief": {
    "title": "You kept table state predictable under pressure",
    "summary": "You kept filtering, stable ordering, page windows, persistent selection, and assistive-technology feedback aligned as the table contract expanded.",
    "takeaways": [
      "Derive the visible page from one filter, sort, and pagination pipeline.",
      "Reset or clamp page state whenever the result window changes.",
      "Track selection by stable domain ids rather than rendered row positions.",
      "Treat table semantics, sort state, labels, and live feedback as correctness requirements."
    ],
    "frameworkNotes": {
      "react": "Use memoized derived collections, functional Set updates, and explicit indeterminate synchronization.",
      "angular": "Use typed getters for the derived pipeline and replace collection state when bindings must refresh.",
      "vue": "Use computed collections and replace Set refs so selection and header state stay reactive."
    }
  },
