            },
            {
              "type": "expectText",
              "selector": ".table-status",
              "text": "Page 1 of 3. Showing 5 of 13 users."
            },
            {
              "type": "setValue",
              "selector": ".search-input",
              "value": "viewer"
            },
            {
              "type": "waitForText",
