    "package.json": "{\"name\":\"vue-snake-game-solution\",\"version\":\"0.1.0\",\"private\":true,\"dependencies\":{\"vue\":\"3.x\"},\"scripts\":{\"serve\":\"vue-cli-service serve\"}}\n",
    "public/index.html": "<!doctype html><html lang=\"en\"><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"><title>Vue SDK • Snake Game (solution)</title></head><body><div id=\"app\"></div></body></html>",
    "src/main.ts": "import { createApp } from 'vue';\nimport App from './App.vue';\nimport './App.css';\n\ncreateApp(App).mount('#app');\n",
    "src/App.vue": "<template>\n  <main class=\"page\">\n    <section class=\"card\">\n      <h1>Snake (Grid + Collision)</h1>\n      <p class=\"subtitle\">Build a keyboard-controlled snake game with safe buffered turns and an explicit full-board win.</p>\n      <div class=\"status-row\">\n        <span class=\"pill\">Score: {{ score }}</span>\n        <span class=\"pill\">Length: {{ snake.length }}</span>\n        <span class=\"pill\" :class=\"{ 'pill--danger': isGameOver }\">{{ statusLabel }}</span>\n      </div>\n      <div class=\"actions\">\n        <button class=\"ghost\" type=\"button\" @click=\"toggleRunning\">{{ isRunning ? 'Pause' : 'Start' }}</button>\n        <button class=\"ghost\" type=\"button\" @click=\"resetGame\">Reset</button>\n      </div>\n      <div class=\"board\" role=\"grid\" aria-label=\"snake board\" :style=\"{ gridTemplateColumns: 'repeat(' + BOARD_SIZE + ', minmax(0, 1fr))' }\">\n        <template v-for=\"row in rows\" :key=\"'row-' + row\">\n          <div v-for=\"col in cols\" :key=\"cellKey(col, row)\" class=\"cell\" :class=\"{\n            'cell--snake': isSnake(col, row),\n            'cell--head': isHead(col, row),\n            'cell--food': isFood(col, row)\n          }\" :aria-label=\"isHead(col, row) ? 'snake head' : (isFood(col, row) ? 'food' : 'empty cell')\"></div>\n        </template>\n      </div>\n      <p class=\"hint\">Use Arrow keys or WASD to move. Space pauses, Enter resets after game over or a win.</p>\n    </section>\n  </main>\n</template>\n\n<script setup lang=\"ts\">\nimport { computed, onBeforeUnmount, onMounted, ref } from 'vue';\nimport { bufferTurn, placeFood, stepSnake, type Direction, type Point } from './snake-engine';\n\nconst BOARD_SIZE = 14;\nconst STEP_MS = 140;\nconst INITIAL_SNAKE: Point[] = [\n  { x: 6, y: 7 }, { x: 5, y: 7 }, { x: 4, y: 7 }\n];\n\nconst snake = ref<Point[]>(INITIAL_SNAKE.map((point) => ({ ...point })));\nconst direction = ref<Direction>('RIGHT');\nconst bufferedDirection = ref<Direction | null>(null);\nconst food = ref<Point | null>(placeFood(snake.value, BOARD_SIZE));\nconst isRunning = ref(false);\nconst isGameOver = ref(false);\nconst isWon = ref(false);\nconst score = ref(0);\nlet timerId: number | null = null;\n\nconst rows = computed(() => Array.from({ length: BOARD_SIZE }, (_, index) => index));\nconst cols = computed(() => Array.from({ length: BOARD_SIZE }, (_, index) => index));\nconst snakeLookup = computed(() => new Set(snake.value.map((point) => cellKey(point.x, point.y))));\nconst statusLabel = computed(() => isWon.value ? 'You win' : isGameOver.value ? 'Game over' : isRunning.value ? 'Running' : 'Paused');\n\nfunction cellKey(x: number, y: number): string { return String(x) + ',' + String(y); }\nfunction isSnake(x: number, y: number): boolean { return snakeLookup.value.has(cellKey(x, y)); }\nfunction isHead(x: number, y: number): boolean { return snake.value[0]?.x === x && snake.value[0]?.y === y; }\nfunction isFood(x: number, y: number): boolean { return food.value !== null && food.value.x === x && food.value.y === y; }\n\nfunction clearTimer(): void {\n  if (timerId !== null) {\n    clearInterval(timerId);\n    timerId = null;\n  }\n}\nfunction startLoop(): void {\n  if (timerId !== null || isGameOver.value || isWon.value) return;\n  timerId = window.setInterval(tick, STEP_MS);\n}\nfunction pauseLoop(): void { clearTimer(); isRunning.value = false; }\nfunction resetGame(): void {\n  clearTimer();\n  snake.value = INITIAL_SNAKE.map((point) => ({ ...point }));\n  direction.value = 'RIGHT';\n  bufferedDirection.value = null;\n  food.value = placeFood(snake.value, BOARD_SIZE);\n  score.value = 0;\n  isRunning.value = false;\n  isGameOver.value = false;\n  isWon.value = false;\n}\nfunction tick(): void {\n  if (!isRunning.value || isGameOver.value || isWon.value) return;\n  const result = stepSnake({\n    snake: snake.value,\n    direction: direction.value,\n    bufferedDirection: bufferedDirection.value,\n    food: food.value,\n    score: score.value\n  }, BOARD_SIZE);\n  snake.value = result.snake;\n  direction.value = result.direction;\n  bufferedDirection.value = result.bufferedDirection;\n  food.value = result.food;\n  score.value = result.score;\n  if (result.outcome === 'lost') { isGameOver.value = true; pauseLoop(); }\n  else if (result.outcome === 'won') { isWon.value = true; pauseLoop(); }\n}\nfunction toggleRunning(): void {\n  if (isGameOver.value || isWon.value) return;\n  isRunning.value = !isRunning.value;\n  if (isRunning.value) startLoop(); else pauseLoop();\n}\nfunction directionFromKey(key: string): Direction | null {\n  if (key === 'arrowup' || key === 'w') return 'UP';\n  if (key === 'arrowdown' || key === 's') return 'DOWN';\n  if (key === 'arrowleft' || key === 'a') return 'LEFT';\n  if (key === 'arrowright' || key === 'd') return 'RIGHT';\n  return null;\n}\nfunction onKeydown(event: KeyboardEvent): void {\n  const key = String(event.key || '').toLowerCase();\n  if (key === ' ') {\n    event.preventDefault();\n    if (!isGameOver.value && !isWon.value) toggleRunning();\n    return;\n  }\n  if (key === 'enter' && (isGameOver.value || isWon.value)) {\n    event.preventDefault();\n    resetGame();\n    return;\n  }\n  const requested = directionFromKey(key);\n  if (!requested) return;\n  event.preventDefault();\n  bufferedDirection.value = bufferTurn(direction.value, bufferedDirection.value, requested);\n}\n\nonMounted(() => window.addEventListener('keydown', onKeydown));\nonBeforeUnmount(() => { window.removeEventListener('keydown', onKeydown); clearTimer(); });\n</script>\n",
    "src/App.css": ":root{color-scheme:dark;}\nhtml,body{margin:0;height:100%;background:#0a0a0a;}\nbody{font-family:system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial,sans-serif;}\n.page{min-height:100vh;display:grid;place-items:center;padding:24px;background:#0a0a0a;color:#e5e7eb;}\n.card{width:min(700px,100%);background:#0b1020;border:1px solid #1f2937;border-radius:14px;padding:18px;display:grid;gap:14px;}\nh1{margin:0;font-size:22px;font-weight:800;}\n.subtitle{margin:0;color:#9ca3af;font-size:13px;}\n.status-row{display:flex;flex-wrap:wrap;gap:8px;}\n.pill{border:1px solid #334155;border-radius:999px;padding:6px 10px;font-size:12px;color:#d1d5db;background:#0a0f1e;}\n.pill--danger{border-color:#7f1d1d;color:#fecaca;background:rgba(127,29,29,.25);}\n.actions{display:flex;gap:10px;}\n.ghost{background:transparent;color:#e5e7eb;border:1px solid #374151;border-radius:12px;padding:10px 14px;font-weight:700;cursor:pointer;}\n.ghost:hover{border-color:#60a5fa;}\n.board{width:min(560px,100%);display:grid;gap:4px;border-radius:12px;background:#0a0f1e;border:1px solid #334155;padding:8px;}\n.cell{aspect-ratio:1/1;border-radius:4px;background:#111827;}\n.cell--snake{background:#2563eb;}\n.cell--head{background:#93c5fd;}\n.cell--food{background:#f43f5e;}\n.hint{margin:0;color:#94a3b8;font-size:12px;}\n",
    "tsconfig.json": "{\n  \"compilerOptions\": {\n    \"target\": \"ES2020\",\n    \"module\": \"ESNext\",\n    \"moduleResolution\": \"Node\",\n    \"strict\": true,\n    \"allowJs\": true\n  }\n}\n",
    "src/snake-engine.ts": "export type Direction = 'UP' | 'DOWN' | 'LEFT' | 'RIGHT';\nexport type Point = { x: number; y: number };\n\nexport interface SnakeSnapshot {\n  snake: Point[];\n  direction: Direction;\n  bufferedDirection: Direction | null;\n  food: Point | null;\n  score: number;\n}\n\nexport interface SnakeStep extends SnakeSnapshot {\n  outcome: 'moved' | 'lost' | 'won';\n}\n\nconst DELTA: Record<Direction, Point> = {\n  UP: { x: 0, y: -1 },\n  DOWN: { x: 0, y: 1 },\n  LEFT: { x: -1, y: 0 },\n  RIGHT: { x: 1, y: 0 }\n};\n\nconst OPPOSITE: Record<Direction, Direction> = {\n  UP: 'DOWN',\n  DOWN: 'UP',\n  LEFT: 'RIGHT',\n  RIGHT: 'LEFT'\n};\n\nfunction key(point: Point): string {\n  return String(point.x) + ',' + String(point.y);\n}\n\nexport function bufferTurn(\n  committed: Direction,\n  buffered: Direction | null,\n  requested: Direction\n): Direction | null {\n  if (buffered !== null) return buffered;\n  if (requested === committed || OPPOSITE[committed] === requested) return null;\n  return requested;\n}\n\nexport function placeFood(\n  snake: Point[],\n  boardSize: number,\n  random: () => number = Math.random\n): Point | null {\n  const occupied = new Set(snake.map(key));\n  const free: Point[] = [];\n\n  for (let y = 0; y < boardSize; y += 1) {\n    for (let x = 0; x < boardSize; x += 1) {\n      const point = { x, y };\n      if (!occupied.has(key(point))) free.push(point);\n    }\n  }\n\n  if (free.length === 0) return null;\n  const index = Math.min(free.length - 1, Math.floor(random() * free.length));\n  return free[index];\n}\n\nexport function stepSnake(\n  state: SnakeSnapshot,\n  boardSize: number,\n  random: () => number = Math.random\n): SnakeStep {\n  const direction = state.bufferedDirection ?? state.direction;\n  const delta = DELTA[direction];\n  const head = state.snake[0];\n  const nextHead = { x: head.x + delta.x, y: head.y + delta.y };\n  const base = { ...state, direction, bufferedDirection: null };\n\n  if (\n    nextHead.x < 0 ||\n    nextHead.y < 0 ||\n    nextHead.x >= boardSize ||\n    nextHead.y >= boardSize\n  ) {\n    return { ...base, outcome: 'lost' };\n  }\n\n  const ateFood = state.food !== null && key(nextHead) === key(state.food);\n  const collisionBody = ateFood ? state.snake : state.snake.slice(0, -1);\n  if (collisionBody.some((part) => key(part) === key(nextHead))) {\n    return { ...base, outcome: 'lost' };\n  }\n\n  const snake = [nextHead, ...state.snake];\n  if (!ateFood) {\n    snake.pop();\n    return { ...base, snake, outcome: 'moved' };\n  }\n\n  const food = placeFood(snake, boardSize, random);\n  return {\n    ...base,\n    snake,\n    food,\n    score: state.score + 1,\n    outcome: food === null ? 'won' : 'moved'\n  };\n}\n"
  }
}
