{
  "dependencies": {
    "vue": "3.x"
  },
  "openFile": "/src/App.vue",
  "files": {
    "src/App.vue": "<template>\n  <main class=\"app\">\n    <section class=\"layout\">\n      <section class=\"column products-column\">\n        <h1 class=\"title\">Products</h1>\n        <ul class=\"product-list\">\n          <li\n            v-for=\"product in products\"\n            :key=\"product.id\"\n            class=\"product-card\"\n            :data-product-id=\"product.id\"\n          >\n            <div class=\"product-main\">\n              <div class=\"product-name\">{{ product.name }}</div>\n              <div class=\"product-price\">{{ formatCurrency(product.price) }}</div>\n              <div class=\"stock-count\">{{ product.stock }} in stock</div>\n            </div>\n            <button\n              type=\"button\"\n              class=\"add-to-cart\"\n              :disabled=\"quantityFor(product.id) >= product.stock\"\n              :aria-label=\"'Add ' + product.name + ' to cart'\"\n              @click=\"addToCart(product)\"\n            >\n              Add to cart\n            </button>\n          </li>\n        </ul>\n      </section>\n\n      <section class=\"column cart-column\">\n        <header class=\"cart-header\">\n          <h1 class=\"title\">Cart</h1>\n          <p class=\"subtitle\">\n            Total items: <strong class=\"total-qty\">{{ totalQty }}</strong>\n            ·\n            Total: <strong class=\"grand-total\">{{ formatCurrency(grandTotal) }}</strong>\n          </p>\n        </header>\n\n        <ul v-if=\"cartItems.length\" class=\"cart-list\">\n          <li\n            v-for=\"item in cartItems\"\n            :key=\"item.id\"\n            class=\"cart-row\"\n            :data-product-id=\"item.id\"\n          >\n            <div class=\"cart-info\">\n              <div class=\"cart-name\">{{ item.name }}</div>\n              <div class=\"cart-meta\">\n                <span class=\"unit-price\">{{ formatCurrency(item.price) }}</span>\n                <span class=\"times\">x</span>\n                <span class=\"qty\">{{ item.quantity }}</span>\n                <span class=\"equals\">=</span>\n                <span class=\"line-total\">\n                  {{ formatCurrency(item.price * item.quantity) }}\n                </span>\n              </div>\n            </div>\n\n            <div class=\"cart-actions\">\n              <button\n                type=\"button\"\n                class=\"ghost quantity-decrease\"\n                :aria-label=\"'Decrease ' + item.name + ' quantity'\"\n                @click=\"decreaseQty(item)\"\n              >\n                −\n              </button>\n              <button\n                type=\"button\"\n                class=\"ghost quantity-increase\"\n                :disabled=\"item.quantity >= item.stock\"\n                :aria-label=\"'Increase ' + item.name + ' quantity'\"\n                @click=\"increaseQty(item)\"\n              >\n                +\n              </button>\n              <button\n                type=\"button\"\n                class=\"danger remove-item\"\n                :aria-label=\"'Remove ' + item.name + ' from cart'\"\n                @click=\"removeItem(item)\"\n              >\n                Remove\n              </button>\n            </div>\n          </li>\n        </ul>\n        <p v-else class=\"empty\">\n          Your cart is empty. Add something from above.\n        </p>\n\n        <p\n          id=\"cart-status\"\n          class=\"cart-status\"\n          role=\"status\"\n          aria-live=\"polite\"\n          aria-atomic=\"true\"\n        >\n          {{ cartStatus }}\n        </p>\n\n        <form class=\"promo-form\" @submit=\"applyPromo\">\n          <label for=\"promo-code\">Promo code</label>\n          <div class=\"promo-controls\">\n            <input\n              id=\"promo-code\"\n              v-model=\"promoCode\"\n              class=\"promo-input\"\n              aria-describedby=\"promo-feedback\"\n              autocomplete=\"off\"\n            />\n            <button type=\"submit\" class=\"apply-promo\">Apply</button>\n          </div>\n        </form>\n        <p\n          id=\"promo-feedback\"\n          class=\"promo-feedback\"\n          role=\"status\"\n          aria-live=\"polite\"\n          aria-atomic=\"true\"\n        >\n          {{ promoFeedback }}\n        </p>\n\n        <dl class=\"summary\">\n          <div>\n            <dt>Subtotal</dt>\n            <dd class=\"subtotal\">{{ formatCurrency(subtotal) }}</dd>\n          </div>\n          <div>\n            <dt>Discount</dt>\n            <dd class=\"discount\">\n              {{ promoApplied ? '-' : '' }}{{ formatCurrency(discount) }}\n            </dd>\n          </div>\n          <div>\n            <dt>Total</dt>\n            <dd class=\"grand-total\">{{ formatCurrency(grandTotal) }}</dd>\n          </div>\n        </dl>\n\n        <button\n          type=\"button\"\n          class=\"checkout-button\"\n          :disabled=\"cartItems.length === 0\"\n          @click=\"checkout\"\n        >\n          Checkout\n        </button>\n        <p\n          class=\"checkout-status\"\n          role=\"status\"\n          aria-live=\"polite\"\n          aria-atomic=\"true\"\n        >\n          {{ checkoutStatus }}\n        </p>\n      </section>\n    </section>\n  </main>\n</template>\n\n<script setup lang=\"ts\">\nimport { computed, ref } from 'vue';\n\ntype Product = {\n  id: string;\n  name: string;\n  price: number;\n  stock: number;\n};\n\ntype CartItem = Product & {\n  quantity: number;\n};\n\nconst products: Product[] = [\n  { id: 'p1', name: 'Wireless Headphones', price: 129.99, stock: 2 },\n  { id: 'p2', name: 'Mechanical Keyboard', price: 89.5, stock: 3 },\n  { id: 'p3', name: 'Ergonomic Mouse', price: 49.99, stock: 5 },\n  { id: 'p4', name: 'USB-C Hub', price: 39, stock: 1 }\n];\n\nconst cartItems = ref<CartItem[]>([]);\nconst cartStatus = ref('');\nconst promoCode = ref('');\nconst promoApplied = ref(false);\nconst promoFeedback = ref('');\nconst checkoutStatus = ref('');\n\nconst totalQty = computed(() =>\n  cartItems.value.reduce((sum, item) => sum + item.quantity, 0)\n);\nconst subtotal = computed(() =>\n  cartItems.value.reduce(\n    (sum, item) => sum + item.price * item.quantity,\n    0\n  )\n);\nconst discount = computed(() => promoApplied.value ? subtotal.value * 0.1 : 0);\nconst grandTotal = computed(() => subtotal.value - discount.value);\n\nconst currencyFormatter = new Intl.NumberFormat('en-US', {\n  style: 'currency',\n  currency: 'USD',\n  minimumFractionDigits: 2,\n  maximumFractionDigits: 2\n});\n\nfunction formatCurrency(value: number): string {\n  return currencyFormatter.format(value);\n}\n\nfunction quantityFor(productId: string): number {\n  return cartItems.value.find(item => item.id === productId)?.quantity ?? 0;\n}\n\nfunction addToCart(product: Product): void {\n  const currentQuantity = quantityFor(product.id);\n  if (currentQuantity >= product.stock) {\n    cartStatus.value = product.name + ' reached its stock limit.';\n    return;\n  }\n\n  const nextQuantity = currentQuantity + 1;\n  const existing = cartItems.value.find(item => item.id === product.id);\n  cartItems.value = existing\n    ? cartItems.value.map(item =>\n        item.id === product.id\n          ? { ...item, quantity: Math.min(item.quantity + 1, item.stock) }\n          : item\n      )\n    : [...cartItems.value, { ...product, quantity: 1 }];\n  cartStatus.value = nextQuantity === product.stock\n    ? product.name + ' reached its stock limit.'\n    : '';\n  checkoutStatus.value = '';\n}\n\nfunction increaseQty(item: CartItem): void {\n  const currentQuantity = quantityFor(item.id);\n  if (currentQuantity >= item.stock) {\n    cartStatus.value = item.name + ' reached its stock limit.';\n    return;\n  }\n\n  const nextQuantity = currentQuantity + 1;\n  cartItems.value = cartItems.value.map(currentItem =>\n    currentItem.id === item.id\n      ? {\n          ...currentItem,\n          quantity: Math.min(currentItem.quantity + 1, currentItem.stock)\n        }\n      : currentItem\n  );\n  cartStatus.value = nextQuantity === item.stock\n    ? item.name + ' reached its stock limit.'\n    : '';\n  checkoutStatus.value = '';\n}\n\nfunction decreaseQty(item: CartItem): void {\n  const selected = cartItems.value.find(\n    currentItem => currentItem.id === item.id\n  );\n  if (!selected) return;\n\n  cartItems.value = selected.quantity <= 1\n    ? cartItems.value.filter(currentItem => currentItem.id !== item.id)\n    : cartItems.value.map(currentItem =>\n        currentItem.id === item.id\n          ? { ...currentItem, quantity: currentItem.quantity - 1 }\n          : currentItem\n      );\n  cartStatus.value = '';\n  checkoutStatus.value = '';\n}\n\nfunction removeItem(item: CartItem): void {\n  cartItems.value = cartItems.value.filter(\n    currentItem => currentItem.id !== item.id\n  );\n  cartStatus.value = '';\n  checkoutStatus.value = '';\n}\n\nfunction applyPromo(event?: Event): void {\n  event?.preventDefault();\n  const normalizedCode = promoCode.value.trim().toUpperCase();\n  promoCode.value = normalizedCode;\n\n  if (normalizedCode === 'SAVE10') {\n    promoApplied.value = true;\n    promoFeedback.value = '10% discount applied.';\n    return;\n  }\n\n  promoApplied.value = false;\n  promoFeedback.value = 'Promo code is invalid.';\n}\n\nfunction checkout(): void {\n  if (!cartItems.value.length) return;\n  cartItems.value = [];\n  cartStatus.value = '';\n  promoCode.value = '';\n  promoApplied.value = false;\n  promoFeedback.value = '';\n  checkoutStatus.value = 'Order placed.';\n}\n</script>\n",
    "src/App.css": ":root{color-scheme:dark}*{box-sizing:border-box}html,body{margin:0;min-height:100%;background:#020617}body{font-family:system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial,sans-serif}.app{min-height:100vh;display:grid;place-items:center;background:#020617;color:#e5e7eb;padding:24px}.layout{width:min(100%,980px);display:grid;grid-template-columns:repeat(2,minmax(0,1fr));align-items:start;gap:16px}.column{min-width:0;background:#020617;border-radius:16px;border:1px solid #1f2937;padding:16px;display:grid;gap:12px}.title{margin:0;font-size:18px;font-weight:700}.subtitle{margin:4px 0 0;font-size:13px;color:#9ca3af}.product-list,.cart-list{list-style:none;margin:0;padding:0;display:grid;gap:8px}.product-card,.cart-row{display:flex;justify-content:space-between;align-items:center;gap:12px;padding:10px;border-radius:12px;border:1px solid #1f2937;background:#020617}.product-main,.cart-info{min-width:0;display:grid;gap:3px}.product-name,.cart-name{font-size:14px;font-weight:600;overflow-wrap:anywhere}.product-price{font-size:13px;color:#a3e635}.stock-count{font-size:12px;color:#94a3b8}.cart-header{display:grid;gap:4px}.cart-meta{display:flex;align-items:center;gap:4px;font-size:12px;color:#9ca3af}.unit-price,.line-total,.subtotal,.discount,.grand-total{font-variant-numeric:tabular-nums}.times,.equals{opacity:.7}.cart-actions{display:flex;gap:6px}button{border-radius:999px;border:1px solid #374151;background:#020617;color:#e5e7eb;padding:7px 12px;font-size:13px;font-weight:600;cursor:pointer}button:hover:not(:disabled){border-color:#a3e635}button:focus-visible,input:focus-visible{outline:3px solid #facc15;outline-offset:2px}button:disabled{cursor:not-allowed;opacity:.45}button.ghost{background:transparent}button.danger{border-color:#f97316;color:#f97316}.empty,.cart-status,.promo-feedback,.checkout-status{min-height:18px;margin:0;font-size:13px;color:#94a3b8}.cart-status,.promo-feedback,.checkout-status{overflow-wrap:anywhere}.promo-form{display:grid;gap:7px}.promo-form label{font-size:13px;font-weight:700}.promo-controls{display:flex;gap:8px}.promo-input{min-width:0;flex:1;border:1px solid #475569;border-radius:10px;background:#0f172a;color:#f8fafc;padding:9px 11px}.apply-promo,.checkout-button{background:#365314;border-color:#65a30d;color:#ecfccb}.summary{display:grid;gap:6px;margin:0;padding:12px;border:1px solid #1f2937;border-radius:12px}.summary div{display:flex;justify-content:space-between;gap:16px}.summary dt,.summary dd{margin:0}.summary dt{color:#94a3b8}.summary div:last-child{font-weight:800}.discount{color:#bef264}.checkout-button{width:100%;border-radius:10px;padding:10px 14px}@media(max-width:760px){.app{padding:14px}.layout{grid-template-columns:1fr}.product-card,.cart-row{align-items:flex-start}.cart-row{flex-direction:column}.cart-actions{width:100%;justify-content:flex-end;flex-wrap:wrap}}@media(max-width:420px){.product-card{align-items:stretch;flex-direction:column}.promo-controls{align-items:stretch;flex-direction:column}}\n"
  }
}

