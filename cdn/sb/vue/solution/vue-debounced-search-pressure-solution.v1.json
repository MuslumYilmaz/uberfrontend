  "dependencies": {
    "vue": "3.x"
  },
  "openFile": "/src/App.vue",
  "files": {
    "src/App.vue": "<template>\n  <main class=\"main\">\n    <section class=\"card\">\n      <header class=\"header\">\n        <h1 class=\"title\">Debounced Search</h1>\n        <p class=\"subtitle\">\n          Type to search a fake user directory. Search runs 500ms after you stop typing.\n        </p>\n      </header>\n\n      <div class=\"field\">\n        <label class=\"label\" for=\"search-input\">Search</label>\n        <input\n          id=\"search-input\"\n          class=\"input\"\n          type=\"text\"\n          :value=\"query\"\n          @input=\"onInput\"\n          placeholder=\"Start typing a name or email...\"\n          autocomplete=\"off\"\n          aria-describedby=\"search-status\"\n          aria-controls=\"search-results\"\n        />\n      </div>\n\n      <div\n        id=\"search-status\"\n        class=\"status-row\"\n        role=\"status\"\n        aria-live=\"polite\"\n        aria-atomic=\"true\"\n      >\n        <span v-if=\"status === 'loading'\" class=\"status status--loading\">Searching…</span>\n        <span v-else-if=\"status === 'success'\" class=\"status\">\n          Showing {{ results.length }} result(s) for \"{{ query }}\"\n        </span>\n        <span v-else-if=\"status === 'idle'\" class=\"status status--muted\">\n          Start typing to search.\n        </span>\n        <span v-else-if=\"status === 'error'\" class=\"status status--error\" role=\"alert\">\n          {{ error }}\n        </span>\n      </div>\n\n      <div id=\"search-results\" class=\"results-region\" v-bind=\"{ 'aria-busy': isLoading }\">\n        <ul v-if=\"status === 'success'\" class=\"results\" aria-label=\"Search results\">\n          <li v-for=\"result in results\" :key=\"result.id\" class=\"result-row\">\n            <div class=\"result-name\">{{ result.name }}</div>\n            <div class=\"result-email\">{{ result.email }}</div>\n          </li>\n        </ul>\n        <p v-else-if=\"status === 'empty'\" class=\"empty\">\n          No results found for \"{{ query }}\".\n        </p>\n      </div>\n    </section>\n  </main>\n</template>\n\n<script setup lang=\"ts\">\nimport { computed, onUnmounted, ref, watch } from 'vue';\n\ninterface Result {\n  id: number;\n  name: string;\n  email: string;\n}\n\ntype SearchStatus = 'idle' | 'loading' | 'success' | 'empty' | 'error';\n\nconst FAKE_DATA: Result[] = [\n  { id: 1, name: 'Alice Johnson', email: 'alice@example.com' },\n  { id: 2, name: 'Bob Smith', email: 'bob@example.com' },\n  { id: 3, name: 'Charlie Kim', email: 'charlie@example.com' },\n  { id: 4, name: 'Diana Lopez', email: 'diana@example.com' },\n  { id: 5, name: 'Ethan Brown', email: 'ethan@example.com' },\n  { id: 6, name: 'Fiona Patel', email: 'fiona@example.com' }\n];\n\nfunction abortError(): DOMException {\n  return new DOMException('Search aborted', 'AbortError');\n}\n\nfunction fakeApiSearch(term: string, signal: AbortSignal): Promise<Result[]> {\n  const normalized = term.trim().toLowerCase();\n\n  return new Promise((resolve, reject) => {\n    let settled = false;\n    const timeoutId = window.setTimeout(() => {\n      if (settled) return;\n      settled = true;\n      signal.removeEventListener('abort', onAbort);\n\n      if (normalized === 'error') {\n        reject(new Error('Fake API error'));\n        return;\n      }\n\n      resolve(FAKE_DATA.filter((item) => (\n        item.name.toLowerCase().includes(normalized)\n        || item.email.toLowerCase().includes(normalized)\n      )));\n    }, 600);\n\n    const onAbort = () => {\n      if (settled) return;\n      settled = true;\n      window.clearTimeout(timeoutId);\n      signal.removeEventListener('abort', onAbort);\n      reject(abortError());\n    };\n\n    signal.addEventListener('abort', onAbort, { once: true });\n    if (signal.aborted) onAbort();\n  });\n}\n\nconst query = ref('');\nconst results = ref<Result[]>([]);\nconst status = ref<SearchStatus>('idle');\nconst error = ref<string | null>(null);\nconst isLoading = computed(() => status.value === 'loading');\nlet requestGeneration = 0;\n\nconst stopWatch = watch(query, (value, _oldValue, onInvalidate) => {\n  const generation = ++requestGeneration;\n  const normalized = value.trim();\n\n  if (!normalized) {\n    results.value = [];\n    error.value = null;\n    status.value = 'idle';\n    return;\n  }\n\n  const controller = new AbortController();\n  results.value = [];\n  error.value = null;\n  status.value = 'loading';\n\n  const debounceId = window.setTimeout(() => {\n    fakeApiSearch(normalized, controller.signal)\n      .then((data) => {\n        if (controller.signal.aborted || requestGeneration !== generation) return;\n        results.value = data;\n        error.value = null;\n        status.value = data.length ? 'success' : 'empty';\n      })\n      .catch((reason: unknown) => {\n        if (controller.signal.aborted || requestGeneration !== generation) return;\n        results.value = [];\n        error.value = reason instanceof Error ? reason.message : 'Something went wrong.';\n        status.value = 'error';\n      });\n  }, 500);\n\n  onInvalidate(() => {\n    window.clearTimeout(debounceId);\n    controller.abort();\n  });\n});\n\nconst onInput = (event: Event) => {\n  const value = (event.target as HTMLInputElement).value;\n  requestGeneration += 1;\n  query.value = value;\n  results.value = [];\n  error.value = null;\n  status.value = value.trim() ? 'loading' : 'idle';\n};\n\nonUnmounted(() => {\n  requestGeneration += 1;\n  stopWatch();\n});\n</script>\n",
    "src/App.css": ":root { color-scheme: dark; }\nhtml, body { margin: 0; height: 100%; background:#020617; font-family: system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, sans-serif; }\n\n.main { min-height:100vh; background:#020617; color:#e5e7eb; display:grid; place-items:center; padding:24px; }\n.card { width:100%; max-width:640px; background:#020617; border-radius:16px; border:1px solid #1f2937; padding:18px 18px 16px; display:grid; gap:16px; }\n.header { display:grid; gap:4px; }\n.title { margin:0; font-size:20px; font-weight:700; }\n.subtitle { margin:0; font-size:13px; color:#9ca3af; }\n.field { display:grid; gap:6px; }\n.label { font-size:13px; color:#9ca3af; }\n.input { width:100%; border-radius:999px; border:1px solid #374151; background:#020617; color:#e5e7eb; padding:8px 12px; font-size:14px; outline:none; }\n.input:focus { border-color:#a3e635; box-shadow:0 0 0 1px #a3e63533; }\n.status-row { min-height:18px; font-size:12px; display:flex; align-items:center; }\n.status { color:#9ca3af; }\n.status--loading { color:#e5e7eb; }\n.status--muted { color:#6b7280; }\n.status--error { color:#f97316; }\n.results-region { min-height:1px; }\n.results { list-style:none; margin:0; padding:0; display:grid; gap:8px; }\n.result-row { padding:8px 10px; border-radius:10px; border:1px solid #1f2937; background:#020617; display:grid; gap:2px; }\n.result-name { font-size:14px; font-weight:600; }\n.result-email { font-size:12px; color:#9ca3af; font-variant-numeric:tabular-nums; }\n.empty { margin:0; font-size:13px; color:#6b7280; }\n"
  }
}
