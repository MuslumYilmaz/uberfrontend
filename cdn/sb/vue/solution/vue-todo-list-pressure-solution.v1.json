{
  "dependencies": {
    "vue": "3.x"
  },
  "openFile": "/src/App.vue",
  "files": {
    "src/App.vue": "<template>\n  <main class=\"main\">\n    <section class=\"section\">\n      <h1>Pressure Todo List</h1>\n      <div class=\"card\">\n        <form class=\"input-row todo-form\" aria-label=\"Add task\" @submit=\"addTask\">\n          <input\n            id=\"new-task\"\n            v-model=\"newTask\"\n            class=\"input\"\n            placeholder=\"Add a task\"\n            autocomplete=\"off\"\n            aria-label=\"New todo\"\n            aria-controls=\"todo-items\"\n            aria-describedby=\"todo-instructions items-left\"\n          />\n          <button type=\"submit\" class=\"primary\" :disabled=\"addDisabled\">Add</button>\n        </form>\n        <p id=\"todo-instructions\" class=\"instructions\">\n          Press Enter to add. Use Edit to rename a task.\n        </p>\n\n        <ul id=\"todo-items\" class=\"list\" aria-label=\"Todo items\">\n          <li v-for=\"todo in visibleTodos\" :key=\"todo.id\" class=\"item\">\n            <div class=\"item-main\">\n              <input\n                class=\"todo-checkbox\"\n                type=\"checkbox\"\n                :checked=\"todo.done\"\n                :aria-label=\"'Mark ' + todo.text + (todo.done ? ' active' : ' complete')\"\n                @change=\"toggleTask(todo.id)\"\n              />\n              <input\n                v-if=\"editingId === todo.id\"\n                v-model=\"editDraft\"\n                class=\"edit-input\"\n                :aria-label=\"'Edit task ' + todo.text\"\n                @keydown=\"onEditKeydown\"\n              />\n              <span v-else class=\"todo-text\" :class=\"{ done: todo.done }\">\n                {{ todo.text }}\n              </span>\n            </div>\n            <div class=\"item-actions\">\n              <button\n                type=\"button\"\n                class=\"ghost edit-task\"\n                :data-id=\"todo.id\"\n                :disabled=\"editingId === todo.id\"\n                :aria-label=\"'Edit ' + todo.text\"\n                @click=\"startEditing(todo)\"\n              >\n                Edit\n              </button>\n              <button\n                type=\"button\"\n                class=\"ghost remove-task\"\n                :aria-label=\"'Remove ' + todo.text\"\n                @click=\"removeTask(todo.id)\"\n              >\n                Remove\n              </button>\n            </div>\n          </li>\n        </ul>\n        <p v-if=\"visibleTodos.length === 0\" class=\"empty\">\n          {{ todos.length ? 'No tasks in this filter.' : 'No tasks yet.' }}\n        </p>\n\n        <div class=\"footer\">\n          <div class=\"filters\" role=\"group\" aria-label=\"Filter tasks\">\n            <button type=\"button\" class=\"filter-button filter-all\" :aria-pressed=\"filter === 'all'\" @click=\"setFilter('all')\">All</button>\n            <button type=\"button\" class=\"filter-button filter-active\" :aria-pressed=\"filter === 'active'\" @click=\"setFilter('active')\">Active</button>\n            <button type=\"button\" class=\"filter-button filter-completed\" :aria-pressed=\"filter === 'completed'\" @click=\"setFilter('completed')\">Completed</button>\n          </div>\n          <div class=\"footer-row\">\n            <p id=\"items-left\" class=\"items-left\" role=\"status\" aria-live=\"polite\" aria-atomic=\"true\">\n              {{ remainingLabel }}\n            </p>\n            <button type=\"button\" class=\"ghost clear-completed\" :disabled=\"!hasCompleted\" @click=\"clearCompleted\">\n              Clear completed\n            </button>\n          </div>\n        </div>\n\n        <div v-if=\"pendingUndo\" class=\"undo-bar\" role=\"status\" aria-live=\"polite\" aria-atomic=\"true\">\n          <span>Removed {{ pendingUndo.item.text }}.</span>\n          <button\n            type=\"button\"\n            class=\"undo-button\"\n            :aria-label=\"'Undo removal of ' + pendingUndo.item.text\"\n            @click=\"undoRemoval\"\n          >\n            Undo\n          </button>\n        </div>\n        <p class=\"visually-hidden\" aria-live=\"polite\" aria-atomic=\"true\">{{ liveMessage }}</p>\n      </div>\n    </section>\n  </main>\n</template>\n\n<script setup lang=\"ts\">\nimport { computed, nextTick, onUnmounted, ref } from 'vue';\n\ntype Todo = {\n  id: number;\n  text: string;\n  done: boolean;\n};\n\ntype Filter = 'all' | 'active' | 'completed';\n\ntype PendingUndo = {\n  item: Todo;\n  index: number;\n};\n\nconst newTask = ref('');\nconst todos = ref([] as Todo[]);\nconst filter = ref<Filter>('all');\nconst editingId = ref<number | null>(null);\nconst editDraft = ref('');\nconst pendingUndo = ref<PendingUndo | null>(null);\nconst liveMessage = ref('');\nlet nextTodoId = 1;\nlet undoTimerId: number | null = null;\n\nconst addDisabled = computed(() => !newTask.value.trim());\nconst visibleTodos = computed(() => {\n  if (filter.value === 'active') return todos.value.filter((todo) => !todo.done);\n  if (filter.value === 'completed') return todos.value.filter((todo) => todo.done);\n  return todos.value;\n});\nconst remainingCount = computed(() => todos.value.filter((todo) => !todo.done).length);\nconst remainingLabel = computed(() => (\n  remainingCount.value === 1\n    ? '1 item left'\n    : remainingCount.value + ' items left'\n));\nconst hasCompleted = computed(() => todos.value.some((todo) => todo.done));\n\nconst clearUndoTimer = () => {\n  if (undoTimerId !== null) {\n    window.clearTimeout(undoTimerId);\n    undoTimerId = null;\n  }\n};\n\nconst addTask = (event?: Event) => {\n  event?.preventDefault();\n  const normalizedTask = newTask.value.trim();\n  if (!normalizedTask) return;\n  todos.value = [\n    ...todos.value,\n    { id: nextTodoId++, text: normalizedTask, done: false }\n  ];\n  newTask.value = '';\n  liveMessage.value = 'Added ' + normalizedTask + '.';\n};\n\nconst toggleTask = (taskKey: number) => {\n  todos.value = todos.value.map((todo) => (\n    todo.id === taskKey ? { ...todo, done: !todo.done } : todo\n  ));\n};\n\nconst setFilter = (nextFilter: Filter) => {\n  filter.value = nextFilter;\n};\n\nconst startEditing = async (selectedTodo: Todo) => {\n  editingId.value = selectedTodo.id;\n  editDraft.value = selectedTodo.text;\n  await nextTick();\n  const editControl = document.querySelector<HTMLInputElement>('.edit-input');\n  editControl?.focus();\n  editControl?.select();\n};\n\nconst finishEditing = async (saveChanges: boolean) => {\n  if (editingId.value === null) return;\n  const editingKey = editingId.value;\n  const normalizedDraft = editDraft.value.trim();\n  if (saveChanges && normalizedDraft) {\n    todos.value = todos.value.map((todo) => (\n      todo.id === editingKey ? { ...todo, text: normalizedDraft } : todo\n    ));\n    liveMessage.value = 'Updated task to ' + normalizedDraft + '.';\n  }\n  editingId.value = null;\n  editDraft.value = '';\n  await nextTick();\n  const editControl = document.querySelector<HTMLButtonElement>(\n    '.edit-task[data-id=\"' + editingKey + '\"]'\n  );\n  editControl?.focus();\n};\n\nconst onEditKeydown = (event: KeyboardEvent) => {\n  if (event.key === 'Enter') {\n    event.preventDefault();\n    void finishEditing(true);\n  } else if (event.key === 'Escape') {\n    event.preventDefault();\n    void finishEditing(false);\n  }\n};\n\nconst removeTask = (taskKey: number) => {\n  const removedPosition = todos.value.findIndex((todo) => todo.id === taskKey);\n  if (removedPosition < 0) return;\n  const removedTodo = todos.value[removedPosition];\n  clearUndoTimer();\n  todos.value = todos.value.filter((todo) => todo.id !== taskKey);\n  pendingUndo.value = { item: removedTodo, index: removedPosition };\n  liveMessage.value = 'Removed ' + removedTodo.text + '. Undo available for 5 seconds.';\n  undoTimerId = window.setTimeout(() => {\n    undoTimerId = null;\n    pendingUndo.value = null;\n    liveMessage.value = 'Undo expired for ' + removedTodo.text + '.';\n  }, 5000);\n};\n\nconst undoRemoval = () => {\n  const snapshot = pendingUndo.value;\n  if (!snapshot) return;\n  clearUndoTimer();\n  if (!todos.value.some((todo) => todo.id === snapshot.item.id)) {\n    const restoredTodos = [...todos.value];\n    restoredTodos.splice(\n      Math.min(snapshot.index, restoredTodos.length),\n      0,\n      snapshot.item\n    );\n    todos.value = restoredTodos;\n  }\n  pendingUndo.value = null;\n  liveMessage.value = 'Restored ' + snapshot.item.text + '.';\n};\n\nconst clearCompleted = () => {\n  todos.value = todos.value.filter((todo) => !todo.done);\n  liveMessage.value = 'Cleared completed tasks.';\n};\n\nonUnmounted(clearUndoTimer);\n</script>\n",
    "src/App.css": ":root{color-scheme:dark}*{box-sizing:border-box}html,body{margin:0;min-height:100%;background:#020617;font-family:system-ui,-apple-system,Segoe UI,Roboto,sans-serif}.main{min-height:100vh;display:grid;place-items:center;padding:24px;color:#e5e7eb}.section{width:min(100%,620px);display:grid;gap:16px}.section h1{margin:0;font-size:22px}.card{display:grid;gap:14px;padding:18px;border:1px solid #334155;border-radius:16px;background:#0b1020}.input-row{display:flex;gap:8px}.input{min-width:0;flex:1;padding:10px 12px;border:1px solid #475569;border-radius:10px;background:#020617;color:#f8fafc}.input:focus,.edit-input:focus,button:focus-visible{outline:3px solid #facc15;outline-offset:2px}.primary,.filter-button,.ghost,.undo-button{border:0;border-radius:9px;padding:9px 12px;font-weight:700;cursor:pointer}.primary{background:#a3e635;color:#172554}.primary:disabled,.clear-completed:disabled{opacity:.45;cursor:not-allowed}.instructions{margin:0;color:#94a3b8;font-size:12px}.list{list-style:none;margin:0;padding:0;display:grid;gap:8px}.item{display:grid;grid-template-columns:minmax(0,1fr) auto;align-items:center;gap:10px;padding:10px;border:1px solid #1e293b;border-radius:11px;background:#020617}.item-main{min-width:0;display:flex;align-items:center;gap:9px}.todo-checkbox{inline-size:18px;block-size:18px;accent-color:#84cc16}.todo-text{overflow-wrap:anywhere}.todo-text.done{text-decoration:line-through;color:#94a3b8}.item-actions{display:flex;gap:6px}.ghost,.filter-button{border:1px solid #475569;background:transparent;color:#e2e8f0}.edit-input{width:100%;padding:7px 9px;border:1px solid #64748b;border-radius:8px;background:#111827;color:#f8fafc}.empty{margin:0;padding:12px;text-align:center;color:#94a3b8}.footer{display:grid;gap:10px}.filters{display:flex;flex-wrap:wrap;gap:7px}.filter-button[aria-pressed=\"true\"]{border-color:#a3e635;background:#365314;color:#ecfccb}.footer-row{display:flex;flex-wrap:wrap;align-items:center;justify-content:space-between;gap:10px}.items-left{margin:0;color:#cbd5e1;font-size:13px}.clear-completed{padding:7px 10px}.undo-bar{display:flex;align-items:center;justify-content:space-between;gap:12px;padding:10px 12px;border:1px solid #ca8a04;border-radius:10px;background:#422006;color:#fef9c3}.undo-button{background:#facc15;color:#422006}.visually-hidden{position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0}@media(max-width:520px){.main{padding:14px}.input-row{align-items:stretch;flex-direction:column}.item{grid-template-columns:1fr}.item-actions{justify-content:flex-end}}\n"
  }
}
