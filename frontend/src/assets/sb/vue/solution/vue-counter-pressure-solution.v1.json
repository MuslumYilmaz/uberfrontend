{
  "dependencies": {
    "vue": "3.x"
  },
  "openFile": "/src/App.vue",
  "files": {
    "src/App.vue": "<template>\n  <main class=\"main\">\n    <section class=\"section\">\n      <h1>Pressure Counter</h1>\n      <div class=\"counter-control\" tabindex=\"0\" aria-describedby=\"counter-shortcuts\" @keydown=\"onCounterKeydown\">\n        <div id=\"counter-value\" class=\"value\" role=\"status\" aria-live=\"polite\">{{ count }}</div>\n        <label class=\"step-label\" for=\"step-size\">Step size</label>\n        <select id=\"step-size\" class=\"step-select\" :value=\"step\" @change=\"setStep\">\n          <option value=\"1\">1</option>\n          <option value=\"5\">5</option>\n          <option value=\"10\">10</option>\n        </select>\n        <p id=\"counter-shortcuts\" class=\"shortcuts\">Focus this card: ArrowUp adds, ArrowDown subtracts, Home resets.</p>\n        <div class=\"actions\">\n          <button type=\"button\" @click=\"dec\" :disabled=\"isZero\" aria-label=\"decrement\">−</button>\n          <button type=\"button\" @click=\"inc\" aria-label=\"increment\">+</button>\n          <button type=\"button\" @click=\"reset\" class=\"ghost\" aria-label=\"reset\">Reset</button>\n          <button type=\"button\" class=\"auto-toggle\" :aria-pressed=\"autoRunning\" @click=\"toggleAuto\">{{ autoRunning ? 'Pause' : 'Start' }}</button>\n        </div>\n      </div>\n    </section>\n  </main>\n</template>\n\n<script setup lang=\"ts\">\nimport { computed, onUnmounted, ref } from 'vue';\n\nconst count = ref(0);\nconst step = ref(1);\nconst autoRunning = ref(false);\nconst intervalId = ref<number | null>(null);\nconst isZero = computed(() => count.value === 0);\n\nconst setStep = (event: Event) => {\n  step.value = Number((event.target as HTMLSelectElement).value);\n};\n\nconst inc = () => {\n  count.value += step.value;\n};\n\nconst dec = () => {\n  count.value = Math.max(0, count.value - step.value);\n};\n\nconst stopAuto = () => {\n  if (intervalId.value !== null) {\n    window.clearInterval(intervalId.value);\n    intervalId.value = null;\n  }\n  autoRunning.value = false;\n};\n\nconst toggleAuto = () => {\n  if (intervalId.value !== null) {\n    stopAuto();\n    return;\n  }\n  autoRunning.value = true;\n  inc();\n  intervalId.value = window.setInterval(inc, 500);\n};\n\nconst reset = () => {\n  stopAuto();\n  count.value = 0;\n};\n\nconst onCounterKeydown = (event: KeyboardEvent) => {\n  const target = event.target as HTMLElement;\n  if (['BUTTON', 'SELECT', 'INPUT', 'TEXTAREA'].includes(target.tagName) || target.isContentEditable) return;\n  if (event.key === 'ArrowUp') inc();\n  else if (event.key === 'ArrowDown') dec();\n  else if (event.key === 'Home') reset();\n  else return;\n  event.preventDefault();\n};\n\nonUnmounted(stopAuto);\n</script>\n",
    "src/App.css": ":root{color-scheme:dark}html,body{margin:0;min-height:100%;background:#0a0a0a;font-family:system-ui,-apple-system,Segoe UI,Roboto,sans-serif}.main{min-height:100vh;display:grid;place-items:center;padding:24px;color:#e5e7eb}.section{width:min(100%,440px);display:grid;gap:16px}.section h1{margin:0;font-size:20px}.counter-control{display:grid;gap:12px;padding:20px;border:1px solid #334155;border-radius:16px;background:#0b1020;outline:none}.counter-control:focus-visible{box-shadow:0 0 0 3px #facc15}.value{font-size:48px;line-height:1;font-weight:800;text-align:center}.step-label{font-size:13px;font-weight:700}.step-select{width:100%;padding:9px 10px;border:1px solid #475569;border-radius:9px;background:#111827;color:#f8fafc}.shortcuts{margin:0;color:#cbd5e1;font-size:12px;line-height:1.45}.actions{display:flex;flex-wrap:wrap;gap:8px;justify-content:center}.actions button{padding:9px 13px;border:0;border-radius:10px;background:#a3e635;color:#111827;font-weight:750;cursor:pointer}.actions button[disabled]{opacity:.5;cursor:not-allowed}.actions .ghost{background:transparent;color:#e5e7eb;border:1px solid #475569}.actions .auto-toggle{background:#facc15}\n"
  }
}
