{
  "dependencies": {
    "vue": "3.x"
  },
  "openFile": "/src/App.vue",
  "files": {
    "src/App.vue": "<template>\n  <main class=\"page\">\n    <section class=\"card\">\n      <header class=\"header\">\n        <div>\n          <h1>User directory</h1>\n          <p class=\"subtitle\">Filter, sort, paginate, and select users without losing state.</p>\n        </div>\n        <p id=\"result-summary\" class=\"result-summary\">{{ resultSummary }}</p>\n      </header>\n\n      <div class=\"toolbar\">\n        <label class=\"field search-field\">\n          <span>Search users</span>\n          <input\n            v-model=\"query\"\n            class=\"search-input\"\n            type=\"search\"\n            aria-label=\"Search users\"\n            aria-describedby=\"result-summary\"\n            autocomplete=\"off\"\n            placeholder=\"Search by name, email, or role...\"\n            @input=\"onSearchInput\"\n            @keydown=\"onSearchKeyDown\"\n          />\n        </label>\n\n        <label class=\"field page-size-field\">\n          <span>Rows per page</span>\n          <select\n            class=\"page-size\"\n            aria-label=\"Rows per page\"\n            :value=\"pageSize\"\n            @change=\"onPageSizeChange\"\n          >\n            <option :value=\"5\">5</option>\n            <option :value=\"10\">10</option>\n          </select>\n        </label>\n      </div>\n\n      <div class=\"selection-bar\">\n        <p class=\"selection-summary\">{{ selectionSummary }}</p>\n        <button\n          type=\"button\"\n          class=\"clear-selection\"\n          aria-label=\"Clear selected users\"\n          :disabled=\"selectedIds.size === 0\"\n          @click=\"clearSelection\"\n        >\n          Clear selection\n        </button>\n      </div>\n\n      <div class=\"table-scroll\">\n        <table class=\"table\">\n          <caption>User directory</caption>\n          <thead>\n            <tr>\n              <th class=\"select-header\" scope=\"col\">\n                <span class=\"visually-hidden\">Select</span>\n                <input\n                  class=\"select-page\"\n                  type=\"checkbox\"\n                  aria-label=\"Select all users on this page\"\n                  :checked=\"selectPageState === 'true'\"\n                  :indeterminate=\"selectPageState === 'mixed'\"\n                  :aria-checked=\"selectPageState\"\n                  :disabled=\"pagedUsers.length === 0\"\n                  @change=\"onPageSelection\"\n                />\n              </th>\n              <th\n                class=\"id-header\"\n                scope=\"col\"\n                :aria-sort=\"sortField === 'id' ? (sortDirection === 'asc' ? 'ascending' : 'descending') : undefined\"\n              >\n                <button\n                  type=\"button\"\n                  class=\"sort-button sort-id\"\n                  :class=\"{ active: sortField === 'id' }\"\n                  aria-label=\"Sort by ID\"\n                  @click=\"toggleSort('id')\"\n                >\n                  ID\n                  <span v-if=\"sortField === 'id'\" aria-hidden=\"true\">\n                    {{ sortDirection === 'asc' ? '↑' : '↓' }}\n                  </span>\n                </button>\n              </th>\n              <th\n                class=\"name-header\"\n                scope=\"col\"\n                :aria-sort=\"sortField === 'name' ? (sortDirection === 'asc' ? 'ascending' : 'descending') : undefined\"\n              >\n                <button\n                  type=\"button\"\n                  class=\"sort-button sort-name\"\n                  :class=\"{ active: sortField === 'name' }\"\n                  aria-label=\"Sort by Name\"\n                  @click=\"toggleSort('name')\"\n                >\n                  Name\n                  <span v-if=\"sortField === 'name'\" aria-hidden=\"true\">\n                    {{ sortDirection === 'asc' ? '↑' : '↓' }}\n                  </span>\n                </button>\n              </th>\n              <th class=\"email-header\" scope=\"col\">Email</th>\n              <th\n                class=\"role-header\"\n                scope=\"col\"\n                :aria-sort=\"sortField === 'role' ? (sortDirection === 'asc' ? 'ascending' : 'descending') : undefined\"\n              >\n                <button\n                  type=\"button\"\n                  class=\"sort-button sort-role\"\n                  :class=\"{ active: sortField === 'role' }\"\n                  aria-label=\"Sort by Role\"\n                  @click=\"toggleSort('role')\"\n                >\n                  Role\n                  <span v-if=\"sortField === 'role'\" aria-hidden=\"true\">\n                    {{ sortDirection === 'asc' ? '↑' : '↓' }}\n                  </span>\n                </button>\n              </th>\n            </tr>\n          </thead>\n          <tbody>\n            <tr\n              v-for=\"user in pagedUsers\"\n              :key=\"user.id\"\n              class=\"data-row\"\n              :data-user-id=\"user.id\"\n            >\n              <td>\n                <input\n                  class=\"row-select\"\n                  type=\"checkbox\"\n                  :aria-label=\"'Select ' + user.name\"\n                  :checked=\"selectedIds.has(user.id)\"\n                  @change=\"onRowSelection(user.id, $event)\"\n                />\n              </td>\n              <td class=\"user-id\">{{ user.id }}</td>\n              <td class=\"user-name\">{{ user.name }}</td>\n              <td class=\"user-email\">{{ user.email }}</td>\n              <td class=\"user-role\">{{ user.role }}</td>\n            </tr>\n            <tr v-if=\"pagedUsers.length === 0\" class=\"empty-state\">\n              <td colspan=\"5\">No users found.</td>\n            </tr>\n          </tbody>\n        </table>\n      </div>\n\n      <footer class=\"footer\" role=\"navigation\" aria-label=\"Pagination\">\n        <button\n          type=\"button\"\n          class=\"previous\"\n          :disabled=\"currentPage === 1\"\n          @click=\"goPrevious\"\n        >\n          Previous\n        </button>\n        <span class=\"page-info\">Page {{ currentPage }} of {{ totalPages }}</span>\n        <button\n          type=\"button\"\n          class=\"next\"\n          :disabled=\"currentPage >= totalPages\"\n          @click=\"goNext\"\n        >\n          Next\n        </button>\n      </footer>\n\n      <p\n        class=\"table-status\"\n        role=\"status\"\n        aria-live=\"polite\"\n        aria-atomic=\"true\"\n      >\n        {{ tableStatus }}\n      </p>\n    </section>\n  </main>\n</template>\n\n<script setup lang=\"ts\">\nimport { computed, ref, watch } from 'vue';\n\ntype Role = 'Admin' | 'Editor' | 'Viewer';\ntype SortField = 'id' | 'name' | 'role';\ntype SortDirection = 'asc' | 'desc';\n\ntype User = {\n  id: number;\n  name: string;\n  email: string;\n  role: Role;\n};\n\nconst USERS: User[] = [\n  { id: 1, name: 'Alice Johnson', email: 'alice@example.com', role: 'Admin' },\n  { id: 2, name: 'Bob Smith', email: 'bob@example.com', role: 'Editor' },\n  { id: 3, name: 'Carla Perez', email: 'carla@example.com', role: 'Viewer' },\n  { id: 4, name: 'David Kim', email: 'david@example.com', role: 'Editor' },\n  { id: 5, name: 'Emma Brown', email: 'emma@example.com', role: 'Viewer' },\n  { id: 6, name: 'Frank Wu', email: 'frank@example.com', role: 'Admin' },\n  { id: 7, name: 'Grace Lee', email: 'grace@example.com', role: 'Viewer' },\n  { id: 8, name: 'Henry Ford', email: 'henry@example.com', role: 'Editor' },\n  { id: 9, name: 'Ivy Stone', email: 'ivy@example.com', role: 'Viewer' },\n  { id: 10, name: 'Jack Ryan', email: 'jack@example.com', role: 'Viewer' },\n  { id: 11, name: 'Karen Diaz', email: 'karen@example.com', role: 'Editor' },\n  { id: 12, name: 'Leo Walker', email: 'leo@example.com', role: 'Viewer' },\n  { id: 13, name: 'Mia Clark', email: 'mia@example.com', role: 'Admin' }\n];\n\nconst query = ref('');\nconst pageSize = ref(5);\nconst currentPage = ref(1);\nconst sortField = ref<SortField>('id');\nconst sortDirection = ref<SortDirection>('asc');\nconst selectedIds = ref<Set<number>>(new Set<number>());\nconst statusOverride = ref('');\n\nconst filteredUsers = computed<User[]>(() => {\n  const needle = query.value.trim().toLowerCase();\n  if (!needle) return USERS;\n\n  return USERS.filter((user) => {\n    const searchable = (\n      user.name + ' ' + user.email + ' ' + user.role\n    ).toLowerCase();\n    return searchable.includes(needle);\n  });\n});\n\nconst sortedUsers = computed<User[]>(() => {\n  const sortedCopy = [...filteredUsers.value];\n\n  sortedCopy.sort((leftUser, rightUser) => {\n    let primaryComparison = 0;\n\n    if (sortField.value === 'id') {\n      primaryComparison = leftUser.id - rightUser.id;\n    } else {\n      primaryComparison = leftUser[sortField.value].localeCompare(\n        rightUser[sortField.value],\n        'en',\n        { sensitivity: 'base' }\n      );\n    }\n\n    if (primaryComparison !== 0) {\n      return sortDirection.value === 'asc'\n        ? primaryComparison\n        : -primaryComparison;\n    }\n\n    return leftUser.id - rightUser.id;\n  });\n\n  return sortedCopy;\n});\n\nconst totalPages = computed(() => (\n  Math.max(1, Math.ceil(sortedUsers.value.length / pageSize.value))\n));\n\nconst pagedUsers = computed<User[]>(() => {\n  const startOffset = (currentPage.value - 1) * pageSize.value;\n  return sortedUsers.value.slice(startOffset, startOffset + pageSize.value);\n});\n\nfunction userCountLabel(countValue: number): string {\n  return countValue === 1 ? '1 user' : countValue + ' users';\n}\n\nconst resultSummary = computed(() => (\n  userCountLabel(filteredUsers.value.length) + ' found.'\n));\n\nconst selectionSummary = computed(() => (\n  userCountLabel(selectedIds.value.size) + ' selected.'\n));\n\nconst selectPageState = computed<'false' | 'mixed' | 'true'>(() => {\n  if (!pagedUsers.value.length) return 'false';\n\n  const selectedOnPage = pagedUsers.value.filter(\n    (user) => selectedIds.value.has(user.id)\n  ).length;\n\n  if (selectedOnPage === 0) return 'false';\n  if (selectedOnPage === pagedUsers.value.length) return 'true';\n  return 'mixed';\n});\n\nfunction currentPageStatus(): string {\n  return (\n    'Page ' + currentPage.value + ' of ' + totalPages.value\n    + '. Showing ' + pagedUsers.value.length + ' of '\n    + userCountLabel(filteredUsers.value.length) + '.'\n  );\n}\n\nconst tableStatus = computed(() => (\n  statusOverride.value || currentPageStatus()\n));\n\nwatch(query, () => {\n  currentPage.value = 1;\n});\n\nwatch(pageSize, () => {\n  currentPage.value = 1;\n});\n\nfunction onSearchInput(): void {\n  statusOverride.value = '';\n}\n\nfunction onSearchKeyDown(event: KeyboardEvent): void {\n  if (event.key !== 'Escape') return;\n\n  event.preventDefault();\n  query.value = '';\n  currentPage.value = 1;\n  statusOverride.value = 'Search cleared. 13 users found.';\n}\n\nfunction onPageSizeChange(event: Event): void {\n  const control = event.target as HTMLSelectElement;\n  pageSize.value = Number(control.value) === 10 ? 10 : 5;\n  currentPage.value = 1;\n  statusOverride.value = '';\n}\n\nfunction toggleSort(nextField: SortField): void {\n  if (sortField.value === nextField) {\n    sortDirection.value = sortDirection.value === 'asc' ? 'desc' : 'asc';\n  } else {\n    sortField.value = nextField;\n    sortDirection.value = 'asc';\n  }\n\n  currentPage.value = 1;\n  statusOverride.value = '';\n}\n\nfunction onRowSelection(userId: number, event: Event): void {\n  const control = event.target as HTMLInputElement;\n  const nextSelection = new Set(selectedIds.value);\n\n  if (control.checked) {\n    nextSelection.add(userId);\n  } else {\n    nextSelection.delete(userId);\n  }\n\n  selectedIds.value = nextSelection;\n  statusOverride.value = userCountLabel(nextSelection.size) + ' selected.';\n}\n\nfunction onPageSelection(event: Event): void {\n  const control = event.target as HTMLInputElement;\n  const nextSelection = new Set(selectedIds.value);\n\n  for (const pageUser of pagedUsers.value) {\n    if (control.checked) {\n      nextSelection.add(pageUser.id);\n    } else {\n      nextSelection.delete(pageUser.id);\n    }\n  }\n\n  selectedIds.value = nextSelection;\n  statusOverride.value = userCountLabel(nextSelection.size) + ' selected.';\n}\n\nfunction clearSelection(): void {\n  selectedIds.value = new Set<number>();\n  statusOverride.value = 'Selection cleared. 0 users selected.';\n}\n\nfunction goPrevious(): void {\n  if (currentPage.value <= 1) return;\n  currentPage.value -= 1;\n  statusOverride.value = '';\n}\n\nfunction goNext(): void {\n  if (currentPage.value >= totalPages.value) return;\n  currentPage.value += 1;\n  statusOverride.value = '';\n}\n</script>\n",
    "src/App.css": ":root{color-scheme:dark}*{box-sizing:border-box}html,body{margin:0;min-height:100%;max-width:100%;overflow-x:hidden;background:#020617}body{font-family:system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial,sans-serif}.page{min-height:100vh;min-width:0;display:grid;place-items:center;padding:24px;background:#020617;color:#e5e7eb}.card{width:min(100%,960px);min-width:0;display:grid;gap:14px;padding:20px;border:1px solid #334155;border-radius:16px;background:#0b1020}.header{display:flex;align-items:flex-end;justify-content:space-between;gap:14px}.header h1{margin:0;font-size:22px}.subtitle,.result-summary,.selection-summary,.table-status{margin:0}.subtitle{margin-top:4px;color:#94a3b8;font-size:13px}.result-summary,.selection-summary{color:#cbd5e1;font-size:13px}.toolbar{display:grid;grid-template-columns:minmax(0,1fr) auto;gap:12px;align-items:end}.field{min-width:0;display:grid;gap:6px;color:#cbd5e1;font-size:13px}.search-input,.page-size{width:100%;min-width:0;border:1px solid #475569;border-radius:10px;background:#020617;color:#f8fafc;padding:10px 12px;font:inherit}.page-size{width:112px}.selection-bar{display:flex;align-items:center;justify-content:space-between;gap:12px}.clear-selection,.footer button{border:1px solid #475569;border-radius:10px;background:transparent;color:#e2e8f0;padding:8px 12px;font-weight:700;cursor:pointer}.clear-selection:disabled,.footer button:disabled,.select-page:disabled{opacity:.45;cursor:not-allowed}.table-scroll{max-width:100%;overflow-x:auto;border:1px solid #334155;border-radius:12px}.table{width:100%;min-width:720px;border-collapse:collapse;background:#020617;font-size:13px}.table caption{padding:10px 12px;text-align:left;color:#f8fafc;font-weight:800;background:#111827}.table th,.table td{padding:10px 12px;border-bottom:1px solid #1e293b;text-align:left}.table th{background:#0f172a;color:#cbd5e1}.table tbody tr:last-child td{border-bottom:0}.data-row:nth-child(even){background:#0f172a}.data-row:hover{background:#172554}.sort-button{display:inline-flex;align-items:center;gap:5px;border:0;background:transparent;color:#cbd5e1;padding:2px;font:inherit;font-weight:800;cursor:pointer}.sort-button.active{color:#bef264}.row-select,.select-page{inline-size:17px;block-size:17px;accent-color:#84cc16}.user-id{font-variant-numeric:tabular-nums}.user-name{font-weight:700}.user-email{overflow-wrap:anywhere;color:#cbd5e1}.empty-state td{padding:24px;text-align:center;color:#94a3b8}.footer{display:grid;grid-template-columns:auto minmax(0,1fr) auto;align-items:center;gap:12px}.page-info{text-align:center;color:#cbd5e1;font-size:13px}.table-status{min-height:18px;color:#bef264;font-size:12px;overflow-wrap:anywhere}.visually-hidden{position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0}button:focus-visible,input:focus-visible,select:focus-visible{outline:3px solid #facc15;outline-offset:2px}@media(max-width:640px){.page{place-items:start stretch;padding:12px}.card{padding:14px}.header{align-items:flex-start;flex-direction:column}.toolbar{grid-template-columns:1fr}.page-size{width:100%}.selection-bar{align-items:flex-start;flex-direction:column}.clear-selection{width:100%}.footer{grid-template-columns:1fr 1fr}.page-info{grid-column:1/-1;grid-row:1}.footer button{width:100%}}\n"
  }
}
