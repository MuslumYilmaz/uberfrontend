{
  "dependencies": {
    "vue": "3.x"
  },
  "openFile": "/src/App.vue",
  "files": {
    "src/App.vue": "<template>\n  <main class=\"page\">\n    <section class=\"card\">\n      <header class=\"header\">\n        <h1>Invite people</h1>\n        <p class=\"subtitle\">\n          Add up to five people with autocomplete, custom entries, and full keyboard support.\n        </p>\n      </header>\n\n      <div\n        ref=\"rootRef\"\n        class=\"chip-field\"\n        :data-root-mounted=\"rootRef ? 'true' : 'false'\"\n      >\n        <div v-if=\"chips.length\" class=\"chips\" aria-label=\"Invited people\">\n          <span\n            v-for=\"chip in chips\"\n            :key=\"chip.id\"\n            class=\"chip\"\n            :data-chip-id=\"chip.id\"\n          >\n            <span class=\"chip-label\">{{ chip.label }}</span>\n            <button\n              type=\"button\"\n              class=\"chip-remove\"\n              :aria-label=\"'Remove ' + chip.label\"\n              @click=\"removeChip(chip.id)\"\n            >\n              ×\n            </button>\n          </span>\n        </div>\n\n        <input\n          id=\"invite-input\"\n          v-model=\"query\"\n          class=\"chip-input\"\n          type=\"text\"\n          role=\"combobox\"\n          aria-label=\"Invite people\"\n          aria-autocomplete=\"list\"\n          aria-controls=\"invite-suggestions\"\n          aria-describedby=\"invite-hint invite-limit\"\n          :aria-expanded=\"isOpen\"\n          :aria-activedescendant=\"activeDescendant\"\n          :dataActiveDescendant=\"activeDescendant || undefined\"\n          :aria-disabled=\"isAtLimit\"\n          :disabled=\"isAtLimit\"\n          autocomplete=\"off\"\n          placeholder=\"Type a name or email...\"\n          @focus=\"onFocus\"\n          @keydown=\"onKeyDown\"\n        />\n\n        <ul\n          v-if=\"isOpen\"\n          id=\"invite-suggestions\"\n          class=\"suggestions\"\n          role=\"listbox\"\n          aria-label=\"Invite suggestions\"\n        >\n          <li\n            v-for=\"(item, index) in suggestions\"\n            :id=\"optionId(item)\"\n            :key=\"item.id\"\n            class=\"suggestion\"\n            :class=\"{ active: index === activeIndex }\"\n            role=\"option\"\n            :aria-selected=\"index === activeIndex\"\n            @mousedown.prevent=\"selectSuggestion(item)\"\n            @click=\"selectSuggestion(item)\"\n          >\n            <strong class=\"suggestion-name\">{{ item.label }}</strong>\n            <span class=\"suggestion-email\">{{ item.value }}</span>\n          </li>\n        </ul>\n      </div>\n\n      <p id=\"invite-hint\" class=\"hint\">\n        Arrow keys navigate. Enter or comma adds. Backspace removes the last chip.\n      </p>\n      <p\n        id=\"invite-limit\"\n        class=\"invite-limit\"\n        :class=\"{ 'invite-limit--reached': isAtLimit }\"\n      >\n        {{ limitText }}\n      </p>\n      <p\n        class=\"invite-status\"\n        role=\"status\"\n        aria-live=\"polite\"\n        aria-atomic=\"true\"\n      >\n        {{ liveMessage }}\n      </p>\n    </section>\n  </main>\n</template>\n\n<script setup lang=\"ts\">\nimport { computed, onBeforeUnmount, onMounted, ref, watch } from 'vue';\n\ntype Candidate = {\n  id: string;\n  name: string;\n  email: string;\n};\n\ntype Chip = {\n  id: string;\n  label: string;\n  value: string;\n};\n\nconst MAX_INVITES = 5;\nconst MAX_SUGGESTIONS = 6;\nconst CANDIDATES: Candidate[] = [\n  { id: 'ada', name: 'Ada Lovelace', email: 'ada@frontendatlas.dev' },\n  { id: 'alice', name: 'Alice Johnson', email: 'alice@frontendatlas.dev' },\n  { id: 'bob', name: 'Bob Smith', email: 'bob@frontendatlas.dev' },\n  { id: 'charlie', name: 'Charlie Kim', email: 'charlie@frontendatlas.dev' },\n  { id: 'diana', name: 'Diana Lopez', email: 'diana@frontendatlas.dev' },\n  { id: 'ethan', name: 'Ethan Brown', email: 'ethan@frontendatlas.dev' },\n  { id: 'fiona', name: 'Fiona Patel', email: 'fiona@frontendatlas.dev' },\n  { id: 'george', name: 'George Miller', email: 'george@frontendatlas.dev' }\n];\n\nconst rootRef = ref<HTMLElement | null>(null);\nconst chips = ref<Chip[]>([]);\nconst query = ref('');\nconst isOpen = ref(false);\nconst activeIndex = ref(-1);\nconst liveMessage = ref('');\n\nconst isAtLimit = computed(() => chips.value.length >= MAX_INVITES);\n\nfunction normalize(value: string): string {\n  return value.trim().toLowerCase();\n}\n\nfunction candidateIsSelected(candidate: Candidate): boolean {\n  const candidateValues = [\n    normalize(candidate.id),\n    normalize(candidate.name),\n    normalize(candidate.email)\n  ];\n\n  return chips.value.some((chip) => {\n    const chipValues = [\n      normalize(chip.id),\n      normalize(chip.label),\n      normalize(chip.value)\n    ];\n    return candidateValues.some((value) => chipValues.includes(value));\n  });\n}\n\nconst suggestions = computed<Chip[]>(() => {\n  const needle = normalize(query.value);\n  if (!needle || isAtLimit.value) return [];\n\n  return CANDIDATES\n    .filter((candidate) => {\n      if (candidateIsSelected(candidate)) return false;\n      const searchable = normalize(candidate.name + ' ' + candidate.email);\n      return searchable.includes(needle);\n    })\n    .slice(0, MAX_SUGGESTIONS)\n    .map((candidate) => ({\n      id: candidate.id,\n      label: candidate.name,\n      value: candidate.email\n    }));\n});\n\nconst activeDescendant = computed<string | undefined>(() => {\n  if (!isOpen.value) return undefined;\n  const activeOption = suggestions.value[activeIndex.value];\n  return activeOption ? optionId(activeOption) : undefined;\n});\n\nconst limitText = computed(() => (\n  isAtLimit.value\n    ? 'Invite limit reached (5 of 5).'\n    : chips.value.length + ' of 5 invites used.'\n));\n\nfunction optionId(chip: Chip): string {\n  return 'invite-option-' + chip.id;\n}\n\nfunction closeSuggestions(): void {\n  isOpen.value = false;\n  activeIndex.value = -1;\n}\n\nfunction resetInput(): void {\n  query.value = '';\n  closeSuggestions();\n}\n\nfunction findDuplicate(chip: Chip): Chip | undefined {\n  const nextValues = [\n    normalize(chip.id),\n    normalize(chip.label),\n    normalize(chip.value)\n  ];\n\n  return chips.value.find((existing) => {\n    const existingValues = [\n      normalize(existing.id),\n      normalize(existing.label),\n      normalize(existing.value)\n    ];\n    return nextValues.some((value) => existingValues.includes(value));\n  });\n}\n\nfunction addChip(chip: Chip): void {\n  if (isAtLimit.value) {\n    liveMessage.value = 'Invite limit reached. Remove a person to add another.';\n    resetInput();\n    return;\n  }\n\n  const duplicate = findDuplicate(chip);\n  if (duplicate) {\n    liveMessage.value = duplicate.label + ' is already invited.';\n    resetInput();\n    return;\n  }\n\n  const nextCount = chips.value.length + 1;\n  chips.value = [...chips.value, chip];\n  liveMessage.value = chip.label + ' added. ' + nextCount + ' of 5 invites used.';\n  resetInput();\n}\n\nfunction addCustomFromQuery(): void {\n  const normalizedLabel = query.value.trim();\n  if (!normalizedLabel) {\n    resetInput();\n    return;\n  }\n\n  addChip({\n    id: 'custom-' + normalize(normalizedLabel),\n    label: normalizedLabel,\n    value: normalizedLabel\n  });\n}\n\nfunction selectSuggestion(chip: Chip): void {\n  if (chips.value.some((existing) => existing.id === chip.id)) {\n    resetInput();\n    return;\n  }\n  addChip(chip);\n}\n\nfunction removeChip(chipId: string): void {\n  const target = chips.value.find((chip) => chip.id === chipId);\n  if (!target) return;\n\n  const remaining = chips.value.filter((chip) => chip.id !== chipId);\n  chips.value = remaining;\n  liveMessage.value = target.label + ' removed. ' + remaining.length + ' of 5 invites used.';\n  closeSuggestions();\n}\n\nfunction onKeyDown(event: KeyboardEvent): void {\n  if (event.key === 'Escape') {\n    event.preventDefault();\n    closeSuggestions();\n    return;\n  }\n\n  const options = suggestions.value;\n  const optionCount = options.length;\n\n  if (event.key === 'ArrowDown') {\n    event.preventDefault();\n    if (!optionCount) return;\n    isOpen.value = true;\n    activeIndex.value = activeIndex.value < 0\n      ? 0\n      : (activeIndex.value + 1) % optionCount;\n    return;\n  }\n\n  if (event.key === 'ArrowUp') {\n    event.preventDefault();\n    if (!optionCount) return;\n    isOpen.value = true;\n    activeIndex.value = activeIndex.value < 0\n      ? optionCount - 1\n      : (activeIndex.value - 1 + optionCount) % optionCount;\n    return;\n  }\n\n  if (event.key === 'Enter') {\n    event.preventDefault();\n    const activeOption = options[activeIndex.value];\n    if (isOpen.value && activeOption) {\n      selectSuggestion(activeOption);\n    } else {\n      addCustomFromQuery();\n    }\n    return;\n  }\n\n  if (event.key === ',') {\n    event.preventDefault();\n    addCustomFromQuery();\n    return;\n  }\n\n  if (event.key === 'Backspace' && query.value.length === 0 && chips.value.length) {\n    event.preventDefault();\n    const lastChip = chips.value[chips.value.length - 1];\n    if (lastChip) removeChip(lastChip.id);\n  }\n}\n\nfunction syncOpenState(): void {\n  isOpen.value = !isAtLimit.value\n    && normalize(query.value).length > 0\n    && suggestions.value.length > 0;\n  if (!isOpen.value) activeIndex.value = -1;\n}\n\nwatch(query, () => {\n  activeIndex.value = -1;\n  syncOpenState();\n});\n\nfunction onFocus(): void {\n  syncOpenState();\n}\n\nfunction onDocumentMouseDown(event: MouseEvent): void {\n  const target = event.target as Node | null;\n  if (!target || !rootRef.value) return;\n  if (!rootRef.value.contains(target)) closeSuggestions();\n}\n\nonMounted(() => {\n  document.addEventListener('mousedown', onDocumentMouseDown);\n});\n\nonBeforeUnmount(() => {\n  document.removeEventListener('mousedown', onDocumentMouseDown);\n});\n</script>\n",
    "src/App.css": ":root{color-scheme:dark}*{box-sizing:border-box}html,body{margin:0;min-height:100%;background:#020617}body{font-family:system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial,sans-serif}.page{min-height:100vh;display:grid;place-items:center;padding:24px;background:#020617;color:#e5e7eb}.card{width:min(100%,680px);min-width:0;display:grid;gap:13px;padding:20px;border:1px solid #334155;border-radius:16px;background:#0b1020}.header{display:grid;gap:5px}.header h1{margin:0;font-size:22px}.subtitle,.hint,.invite-limit,.invite-status{margin:0;overflow-wrap:anywhere}.subtitle{color:#94a3b8;font-size:14px;line-height:1.5}.chip-field{position:relative;min-width:0;display:grid;gap:9px;padding:10px;border:1px solid #475569;border-radius:13px;background:#020617}.chip-field:focus-within{border-color:#a3e635;box-shadow:0 0 0 2px rgba(163,230,53,.16)}.chips{display:flex;min-width:0;flex-wrap:wrap;gap:7px}.chip{display:inline-flex;max-width:100%;align-items:center;gap:7px;padding:5px 9px;border:1px solid #36516f;border-radius:999px;background:#172036;color:#e2e8f0;font-size:13px}.chip-label{min-width:0;overflow-wrap:anywhere}.chip-remove{flex:0 0 auto;border:0;background:transparent;color:#cbd5e1;font-size:17px;line-height:1;cursor:pointer;padding:1px}.chip-remove:hover{color:#fff}.chip-input{width:100%;min-width:0;border:0;outline:0;background:transparent;color:#f8fafc;font:inherit;padding:7px 3px}.chip-input::placeholder{color:#64748b}.chip-input:disabled{cursor:not-allowed;color:#94a3b8}.suggestions{position:absolute;z-index:10;top:calc(100% + 8px);left:0;right:0;max-height:260px;overflow:auto;margin:0;padding:0;list-style:none;border:1px solid #334155;border-radius:12px;background:#0f172a;box-shadow:0 16px 34px rgba(0,0,0,.35)}.suggestion{display:grid;gap:2px;padding:10px 12px;border-bottom:1px solid rgba(51,65,85,.65);cursor:pointer}.suggestion:last-child{border-bottom:0}.suggestion:hover,.suggestion.active{background:#365314}.suggestion-name{overflow-wrap:anywhere}.suggestion-email{color:#a7b1c2;font-size:12px;overflow-wrap:anywhere}.hint,.invite-limit,.invite-status{font-size:12px;line-height:1.45}.hint{color:#94a3b8}.invite-limit{color:#cbd5e1}.invite-limit--reached{color:#facc15;font-weight:700}.invite-status{min-height:18px;color:#bef264}button:focus-visible,.chip-input:focus-visible{outline:3px solid #facc15;outline-offset:3px}@media(max-width:520px){.page{place-items:start stretch;padding:12px}.card{padding:15px}.chip-field{padding:9px}.chip{border-radius:10px}.suggestions{max-height:220px}}\n"
  }
}
