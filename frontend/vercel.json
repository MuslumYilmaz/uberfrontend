{
  "version": 2,
  "headers": [
    {
      "source": "/coding",
      "has": [{ "type": "query", "key": "reset" }],
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, follow" }]
    },
    {
      "source": "/coding",
      "has": [{ "type": "query", "key": "kind" }],
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, follow" }]
    },
    {
      "source": "/coding",
      "has": [{ "type": "query", "key": "view" }],
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, follow" }]
    },
    {
      "source": "/coding",
      "has": [{ "type": "query", "key": "category" }],
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, follow" }]
    },
    {
      "source": "/coding",
      "has": [{ "type": "query", "key": "tech" }],
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, follow" }]
    },
    {
      "source": "/coding",
      "has": [{ "type": "query", "key": "q" }],
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, follow" }]
    },
    {
      "source": "/coding",
      "has": [{ "type": "query", "key": "diff" }],
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, follow" }]
    },
    {
      "source": "/coding",
      "has": [{ "type": "query", "key": "imp" }],
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, follow" }]
    },
    {
      "source": "/coding",
      "has": [{ "type": "query", "key": "topic" }],
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, follow" }]
    },
    {
      "source": "/coding",
      "has": [{ "type": "query", "key": "focus" }],
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, follow" }]
    }
  ],
  "redirects": [
    {
      "source": "/guides/interview-blueprint/javascript-prep-path",
      "destination": "/guides/framework-prep/javascript-prep-path",
      "permanent": true
    },
    {
      "source": "/guides/interview-blueprint/react-prep-path",
      "destination": "/guides/framework-prep/react-prep-path",
      "permanent": true
    },
    {
      "source": "/guides/interview-blueprint/angular-prep-path",
      "destination": "/guides/framework-prep/angular-prep-path",
      "permanent": true
    },
    {
      "source": "/guides/interview-blueprint/vue-prep-path",
      "destination": "/guides/framework-prep/vue-prep-path",
      "permanent": true
    },
    { "source": "/:path+/", "destination": "/:path+", "permanent": true }
  ],
  "rewrites": [
    { "source": "/dashboard", "destination": "/index.html" },
    { "source": "/dashboard/:path*", "destination": "/index.html" },
    { "source": "/profile", "destination": "/index.html" },
    { "source": "/profile/:path*", "destination": "/index.html" },
    { "source": "/admin", "destination": "/index.html" },
    { "source": "/admin/:path*", "destination": "/index.html" },
    { "source": "/billing", "destination": "/index.html" },
    { "source": "/billing/:path*", "destination": "/index.html" },
    { "source": "/onboarding", "destination": "/index.html" },
    { "source": "/onboarding/:path*", "destination": "/index.html" },
    { "source": "/track/:slug", "destination": "/index.html" },
    { "source": "/tracks/:slug", "destination": "/index.html" },
    { "source": "/companies/:slug", "destination": "/index.html" },
    { "source": "/companies/:slug/all", "destination": "/index.html" },
    { "source": "/companies/:slug/coding", "destination": "/index.html" },
    { "source": "/companies/:slug/trivia", "destination": "/index.html" },
    { "source": "/companies/:slug/system", "destination": "/index.html" },
    { "source": "/:path*", "destination": "/404", "statusCode": 404 }
  ]
}
