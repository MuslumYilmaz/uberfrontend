{
  "version": 2,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), payment=(), usb=(), interest-cohort=()" },
        { "key": "Content-Security-Policy", "value": "default-src 'self' https: data: blob:; base-uri 'self'; object-src 'none'; frame-ancestors 'self'; upgrade-insecure-requests" },
        { "key": "Content-Security-Policy-Report-Only", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval' https://www.googletagmanager.com https://gumroad.com https://cdn.jsdelivr.net https://esm.sh; script-src-elem 'self' 'unsafe-inline' https://www.googletagmanager.com https://gumroad.com https://cdn.jsdelivr.net https://esm.sh; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: blob: https:; font-src 'self' data: https:; connect-src 'self' https://api.frontendatlas.com https://frontendatlas.vercel.app https://*.ingest.sentry.io https://*.ingest.us.sentry.io https://*.sentry.io https://www.google-analytics.com https://region1.google-analytics.com https://www.googletagmanager.com https://cdn.jsdelivr.net https://esm.sh; worker-src 'self' blob:; frame-src 'self' blob: https://*.lemonsqueezy.com https://gumroad.com https://*.gumroad.com; form-action 'self' https://*.lemonsqueezy.com https://gumroad.com https://*.gumroad.com; base-uri 'self'; object-src 'none'; frame-ancestors 'self'; upgrade-insecure-requests" }
      ]
    },
    {
      "source": "/coding",
      "has": [{ "type": "query", "key": "reset" }],
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, follow" }]
    },
    {
      "source": "/coding",
      "has": [{ "type": "query", "key": "kind" }],
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, follow" }]
    },
    {
      "source": "/coding",
      "has": [{ "type": "query", "key": "view" }],
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, follow" }]
    },
    {
      "source": "/coding",
      "has": [{ "type": "query", "key": "category" }],
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, follow" }]
    },
    {
      "source": "/coding",
      "has": [{ "type": "query", "key": "tech" }],
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, follow" }]
    },
    {
      "source": "/coding",
      "has": [{ "type": "query", "key": "q" }],
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, follow" }]
    },
    {
      "source": "/coding",
      "has": [{ "type": "query", "key": "diff" }],
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, follow" }]
    },
    {
      "source": "/coding",
      "has": [{ "type": "query", "key": "imp" }],
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, follow" }]
    },
    {
      "source": "/coding",
      "has": [{ "type": "query", "key": "topic" }],
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, follow" }]
    },
    {
      "source": "/coding",
      "has": [{ "type": "query", "key": "focus" }],
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, follow" }]
    }
  ],
  "redirects": [
    {
      "source": "/guides/interview-blueprint/javascript-prep-path",
      "destination": "/guides/framework-prep/javascript-prep-path",
      "permanent": true
    },
    {
      "source": "/guides/interview-blueprint/react-prep-path",
      "destination": "/guides/framework-prep/react-prep-path",
      "permanent": true
    },
    {
      "source": "/guides/interview-blueprint/angular-prep-path",
      "destination": "/guides/framework-prep/angular-prep-path",
      "permanent": true
    },
    {
      "source": "/guides/interview-blueprint/vue-prep-path",
      "destination": "/guides/framework-prep/vue-prep-path",
      "permanent": true
    },
    { "source": "/:path+/", "destination": "/:path+", "permanent": true }
  ],
  "rewrites": [
    { "source": "/dashboard", "destination": "/index.html" },
    { "source": "/dashboard/:path*", "destination": "/index.html" },
    { "source": "/profile", "destination": "/index.html" },
    { "source": "/profile/:path*", "destination": "/index.html" },
    { "source": "/admin", "destination": "/index.html" },
    { "source": "/admin/:path*", "destination": "/index.html" },
    { "source": "/billing", "destination": "/index.html" },
    { "source": "/billing/:path*", "destination": "/index.html" },
    { "source": "/onboarding", "destination": "/index.html" },
    { "source": "/onboarding/:path*", "destination": "/index.html" },
    { "source": "/track/:slug", "destination": "/index.html" },
    { "source": "/tracks/:slug", "destination": "/index.html" },
    { "source": "/companies/:slug", "destination": "/index.html" },
    { "source": "/companies/:slug/all", "destination": "/index.html" },
    { "source": "/companies/:slug/coding", "destination": "/index.html" },
    { "source": "/companies/:slug/trivia", "destination": "/index.html" },
    { "source": "/companies/:slug/system", "destination": "/index.html" },
    { "source": "/:path*", "destination": "/404", "statusCode": 404 }
  ]
}
