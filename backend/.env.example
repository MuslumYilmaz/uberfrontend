#
# Backend environment variables (example)
#
# Copy this file to `.env` (which is gitignored) and fill in values.
#

# App
NODE_ENV=development
PORT=3001

# Database
# Local development should use the Mongo `test` database by default.
# Only switch to `MONGO_TARGET=production` for explicit production-local maintenance.
MONGO_TARGET=test
MONGO_URL=mongodb://127.0.0.1:27017/frontendatlas
MONGO_URL_TEST=mongodb://127.0.0.1:27017/test
EXPECTED_MONGO_DB_NAME_TEST=test

# Auth / JWT
# - In production, JWT_SECRET is required and should be 32+ chars.
JWT_SECRET=replace-with-a-strong-secret-at-least-32-chars
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_SESSION_TTL_DAYS=90

# Cookie auth
# - access token is stored in an httpOnly cookie (default name: access_token)
# - COOKIE_SAMESITE=none requires COOKIE_SECURE=true and enables CSRF double-submit checks
COOKIE_SAMESITE=lax
COOKIE_SECURE=false

# OAuth (optional)
# Base URLs used to build OAuth redirect/callback URLs.
SERVER_BASE=http://localhost:3001
FRONTEND_BASE=http://localhost:4200
# Comma-separated allowed frontend origins for CORS/OAuth redirects.
# Include 127.0.0.1 and the common local test/preview ports used in this repo.
FRONTEND_ORIGINS=http://localhost:4200,http://127.0.0.1:4200,http://localhost:4310,http://127.0.0.1:4310,http://localhost:4173,http://127.0.0.1:4173
FRONTEND_ORIGIN=http://localhost:4200

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Proxy / rate limiting
TRUST_PROXY=false

# Activity
WEEKLY_TARGET=5

# Payments / checkout start
BILLING_PROVIDER=lemonsqueezy
# Active hosted checkout providers today: `lemonsqueezy`, `gumroad`.
# `stripe` stays reserved until the full checkout + webhook + portal flow is shipped.
PAYMENTS_MODE=test
# Use `test` for local/E2E. Production should use `live`.
GUMROAD_MONTHLY_URL=
GUMROAD_QUARTERLY_URL=
GUMROAD_ANNUAL_URL=
LEMONSQUEEZY_MONTHLY_URL=
LEMONSQUEEZY_QUARTERLY_URL=
LEMONSQUEEZY_ANNUAL_URL=
LEMONSQUEEZY_LIFETIME_URL=
LEMONSQUEEZY_MONTHLY_URL_TEST=
LEMONSQUEEZY_QUARTERLY_URL_TEST=
LEMONSQUEEZY_ANNUAL_URL_TEST=
LEMONSQUEEZY_LIFETIME_URL_TEST=
LEMONSQUEEZY_MONTHLY_URL_LIVE=
LEMONSQUEEZY_QUARTERLY_URL_LIVE=
LEMONSQUEEZY_ANNUAL_URL_LIVE=
LEMONSQUEEZY_LIFETIME_URL_LIVE=
STRIPE_MONTHLY_URL=
STRIPE_QUARTERLY_URL=
STRIPE_ANNUAL_URL=
STRIPE_LIFETIME_URL=

# Billing / webhook secrets
GUMROAD_WEBHOOK_SECRET=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_WEBHOOK_SECRET_TEST=
LEMONSQUEEZY_WEBHOOK_SECRET_LIVE=
LEMONSQUEEZY_API_KEY=
STRIPE_WEBHOOK_SECRET=

# Bug report email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=

# Bug report endpoint rate limit / payload caps
BUG_REPORT_WINDOW_MS=3600000
BUG_REPORT_MAX=5
BUG_REPORT_MAX_NOTE_CHARS=4000
BUG_REPORT_MAX_URL_CHARS=2000
