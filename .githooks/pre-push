#!/usr/bin/env bash
set -euo pipefail

# Ensure common Node paths are available in non-interactive git hooks.
export PATH="/opt/homebrew/bin:/usr/local/bin:$PATH"

# Load nvm/asdf/fnm if present (git hooks don't source shell profiles).
if [ -s "$HOME/.nvm/nvm.sh" ]; then
  . "$HOME/.nvm/nvm.sh"
fi
if [ -s "$HOME/.asdf/asdf.sh" ]; then
  . "$HOME/.asdf/asdf.sh"
fi
if command -v fnm >/dev/null 2>&1; then
  eval "$(fnm env --use-on-cd)"
fi

# Fallback: add the first nvm-installed node bin to PATH if npm is still missing.
if ! command -v npm >/dev/null 2>&1; then
  for p in "$HOME/.nvm/versions/node"/*/bin; do
    if [ -x "$p/npm" ]; then
      export PATH="$p:$PATH"
      break
    fi
  done
fi

if ! command -v npm >/dev/null 2>&1; then
  echo "[pre-push] ERROR: npm not found. Install Node.js/npm and retry." >&2
  exit 1
fi

ZERO_SHA="0000000000000000000000000000000000000000"
HAVE_REFS=0
CHANGED_FILES="$(mktemp)"
PUSH_COMMITS="$(mktemp)"
BACKEND_SOURCE_FILES="$(mktemp)"
BACKEND_TEST_FILES="$(mktemp)"
BACKEND_NODECHECK_FILES="$(mktemp)"
trap 'rm -f "$CHANGED_FILES" "$PUSH_COMMITS" "$BACKEND_SOURCE_FILES" "$BACKEND_TEST_FILES" "$BACKEND_NODECHECK_FILES"' EXIT
FRONTEND_CHANGE_RE='^(frontend/|cdn/(questions/|incidents/|tradeoff-battles/|practice/)|cdn/data-version\.json$)'
BACKEND_CHANGE_RE='^backend/'

# Collect file paths included in refs being pushed.
while read -r local_ref local_sha remote_ref remote_sha; do
  [ -z "${local_ref:-}" ] && continue
  HAVE_REFS=1

  # Branch/tag deletion.
  if [ "$local_sha" = "$ZERO_SHA" ]; then
    continue
  fi

  commits=()
  if [ "$remote_sha" = "$ZERO_SHA" ]; then
    # New branch/tag push: include commits not already present on remotes.
    while IFS= read -r commit; do
      [ -z "${commit:-}" ] && continue
      commits+=("$commit")
    done < <(git rev-list "$local_sha" --not --remotes 2>/dev/null || true)
    if [ "${#commits[@]}" -eq 0 ]; then
      commits=("$local_sha")
    fi
  else
    # Existing ref update: include all commits reachable in remote..local.
    while IFS= read -r commit; do
      [ -z "${commit:-}" ] && continue
      commits+=("$commit")
    done < <(git rev-list "$remote_sha..$local_sha" 2>/dev/null || true)
    if [ "${#commits[@]}" -eq 0 ]; then
      continue
    fi
  fi

  for commit in "${commits[@]}"; do
    [ -z "${commit:-}" ] && continue
    echo "$commit" >> "$PUSH_COMMITS"
    git diff-tree --root --no-commit-id --name-only -r "$commit" >> "$CHANGED_FILES" || true
  done
done

sort -u -o "$PUSH_COMMITS" "$PUSH_COMMITS"
sort -u -o "$CHANGED_FILES" "$CHANGED_FILES"

HAS_FRONTEND_CHANGES=0
HAS_BACKEND_CHANGES=0

if grep -Eq "$FRONTEND_CHANGE_RE" "$CHANGED_FILES"; then
  HAS_FRONTEND_CHANGES=1
fi

if grep -Eq "$BACKEND_CHANGE_RE" "$CHANGED_FILES"; then
  HAS_BACKEND_CHANGES=1
fi

if [ "$HAVE_REFS" -eq 1 ] && [ "$HAS_FRONTEND_CHANGES" -eq 0 ] && [ "$HAS_BACKEND_CHANGES" -eq 0 ]; then
  echo "[pre-push] No backend/frontend repo changes in push refs. Skipping checks."
  exit 0
fi

if [ "$HAS_BACKEND_CHANGES" -eq 1 ]; then
  while IFS= read -r file; do
    [ -z "${file:-}" ] && continue
    [ -f "$file" ] || continue

    if [[ "$file" =~ ^backend/tests/.*\.test\.js$ ]]; then
      echo "$file" >> "$BACKEND_TEST_FILES"
      echo "$file" >> "$BACKEND_NODECHECK_FILES"
      continue
    fi

    if [[ "$file" =~ ^backend/.*\.js$ ]]; then
      echo "$file" >> "$BACKEND_SOURCE_FILES"
      echo "$file" >> "$BACKEND_NODECHECK_FILES"
    fi
  done < "$CHANGED_FILES"

  sort -u -o "$BACKEND_SOURCE_FILES" "$BACKEND_SOURCE_FILES"
  sort -u -o "$BACKEND_TEST_FILES" "$BACKEND_TEST_FILES"
  sort -u -o "$BACKEND_NODECHECK_FILES" "$BACKEND_NODECHECK_FILES"

  if [ -s "$BACKEND_NODECHECK_FILES" ]; then
    echo "[pre-push] Running backend syntax checks..."
    while IFS= read -r file; do
      [ -z "${file:-}" ] && continue
      if ! node --check "$file"; then
        echo "[pre-push] ERROR: Backend syntax check failed for $file. Push aborted." >&2
        exit 1
      fi
    done < "$BACKEND_NODECHECK_FILES"
    echo "[pre-push] OK: Backend syntax checks passed."
  fi

  if [ -s "$BACKEND_SOURCE_FILES" ]; then
    echo "[pre-push] Running backend related Jest tests..."
    backend_source_args=()
    while IFS= read -r file; do
      [ -z "${file:-}" ] && continue
      backend_source_args+=("$file")
    done < "$BACKEND_SOURCE_FILES"
    if ! npm -C backend test -- --findRelatedTests --passWithNoTests "${backend_source_args[@]}"; then
      echo "[pre-push] ERROR: Backend related tests failed. Push aborted." >&2
      exit 1
    fi
    echo "[pre-push] OK: Backend related Jest tests passed."
  fi

  if [ -s "$BACKEND_TEST_FILES" ]; then
    echo "[pre-push] Running changed backend test files..."
    backend_test_args=()
    while IFS= read -r file; do
      [ -z "${file:-}" ] && continue
      backend_test_args+=("$file")
    done < "$BACKEND_TEST_FILES"
    if ! npm -C backend test -- --runTestsByPath "${backend_test_args[@]}"; then
      echo "[pre-push] ERROR: Changed backend test files failed. Push aborted." >&2
      exit 1
    fi
    echo "[pre-push] OK: Changed backend test files passed."
  fi
fi

if [ "$HAS_FRONTEND_CHANGES" -eq 0 ]; then
  echo "[pre-push] No frontend/cdn changes in push refs. Skipping frontend checks."
  exit 0
fi

echo "[pre-push] Validating coding assist artifact sync (hint/explain/decision-graph)..."
if ! node frontend/scripts/validate-coding-assist-sync.mjs --changed-files "$CHANGED_FILES" --commits-file "$PUSH_COMMITS"; then
  echo "[pre-push] ERROR: Coding assist artifact validation failed. Push aborted." >&2
  exit 1
fi
echo "[pre-push] OK: Coding assist artifact sync check passed."

echo "[pre-push] Running frontend tag/topic/track lints..."
if ! npm -C frontend run lint:tags; then
  echo "[pre-push] ERROR: Frontend tag lint failed. Push aborted." >&2
  exit 1
fi
if ! npm -C frontend run lint:topics; then
  echo "[pre-push] ERROR: Frontend topic lint failed. Push aborted." >&2
  exit 1
fi
if ! npm -C frontend run lint:tracks; then
  echo "[pre-push] ERROR: Frontend track lint failed. Push aborted." >&2
  exit 1
fi
echo "[pre-push] OK: Frontend tag/topic/track lints passed."

echo "[pre-push] Running frontend unit and content verification..."
if ! npm -C frontend run verify:unit-and-content; then
  echo "[pre-push] ERROR: Frontend unit/content verification failed. Push aborted." >&2
  exit 1
fi
echo "[pre-push] OK: Frontend unit/content verification passed."
echo "[pre-push] Running frontend critical E2E verification..."

# Use a dedicated hook port and disable server reuse to avoid conflicts with
# already-running local dev servers or stale processes on :4200.
if ! PLAYWRIGHT_WEB_SERVER=1 PLAYWRIGHT_PORT=4310 PLAYWRIGHT_REUSE_SERVER=0 npm -C frontend run verify:e2e-critical; then
  echo "[pre-push] ERROR: Frontend critical E2E verification failed. Push aborted." >&2
  exit 1
fi

echo "[pre-push] OK: Frontend critical E2E verification passed."
